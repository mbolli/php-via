parameters:
  bootstrapFiles:
    - phpstan-bootstrap.php
    - website/vendor/autoload.php
  dynamicConstantNames:
    - SWOOLE_EVENT_READ
    - SWOOLE_IPC_NONE
  level: 6
  paths:
    - src/
  ignoreErrors:
    # OpenSwoole IDE-helper stub for Timer::clear() declares 0 required params,
    # but the real OpenSwoole extension requires the timer ID argument.
    - message: '#Timer::clear\(\)#'
      identifier: arguments.count
  editorUrl: 'phpstorm://open?file=%%file%%&line=%%line%%'
  editorUrlTitle: '%%file%%:%%line%%'
  type_perfect:
    null_over_false: true
    no_mixed: true
    #narrow_param: true
    #narrow_return: true
  type_coverage:
    declare: 100
    return: 100
    param: 100
    property: 100
    constant: 100
includes:
  - vendor/phpstan/phpstan/conf/bleedingEdge.neon
