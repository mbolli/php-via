<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#2563eb">
    <meta data-signals='{"via_ctx":"{{ contextId }}","_disconnected":false}'>
    <meta data-indicator="_connecting"
        data-on-interval__duration.15s.leading="!$_connecting && @get('{{ basePath }}_sse')"
        data-on-datastar-fetch="el === evt.detail.el &&
                           ((evt.detail.type.startsWith('datastar') && ($_disconnected = false)) ||
                           (['retrying', 'error', 'finished'].includes(evt.detail.type) && ($_disconnected = true)))">
    <meta data-init="window.addEventListener('beforeunload', () => { navigator.sendBeacon('{{ basePath }}_session/close', '{{ contextId }}'); });">
    <link rel="stylesheet" href="{{ basePath }}css/site.css">
    <title>{% block title %}php-via{% endblock %}</title>
    {% block head %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">
    <div data-show="$_disconnected" class="connection-warning">⚠️ Reconnecting…</div>

    <div class="bg-watermark" aria-hidden="true"></div>
    <nav class="site-nav" role="navigation" aria-label="Main navigation">
        <div class="nav-inner">
            <a href="{{ basePath }}" class="nav-logo" aria-label="php-via home">
                <img src="{{ basePath }}logo-icon-128.png" alt="" class="logo-icon" width="32" height="32">
                <span class="logo-text">php-via</span>
            </a>
            <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true">
            <label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </label>
            <ul class="nav-links" role="list">
                <li><a href="{{ basePath }}docs/getting-started"
                    {% if currentRoute starts with '/docs' %}aria-current="page"{% endif %}>Docs</a></li>
                <li><a href="{{ basePath }}examples"
                    {% if currentRoute starts with '/examples' %}aria-current="page"{% endif %}>Examples</a></li>
                <li>
                    <a href="https://github.com/mbolli/php-via" class="nav-github" target="_blank" rel="noopener" aria-label="GitHub">
                        <svg width="20" height="20" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    {% block layout %}
    <main id="content">
        {% block content %}{% endblock %}
    </main>
    {% endblock %}

    <footer class="site-footer">
        <div class="footer-inner">
            <p>
                Built with <strong>php-via</strong> &amp; <a href="https://data-star.dev/" target="_blank" rel="noopener">Datastar</a>.
                <a href="https://github.com/mbolli/php-via" target="_blank" rel="noopener">GitHub</a> ·
                <a href="https://packagist.org/packages/mbolli/php-via" target="_blank" rel="noopener">Packagist</a> ·
                MIT License.
                Maintained by <a href="https://zweiundeins.gmbh" target="_blank" rel="noopener">zwei und eins gmbh</a>.
            </p>
        </div>
    </footer>

    <script type="module" src="{{ basePath }}datastar.js"></script>
    {% block foot_scripts %}{% endblock %}
</body>
</html>
