{% extends 'shells/base.html.twig' %}

{% block body_class %}docs-body{% endblock %}

{% block layout %}
<div class="docs-layout">
    <aside class="docs-sidebar" role="complementary" aria-label="Examples navigation">
        <nav class="sidebar-nav">
            {% macro navlink(href, label, currentRoute, basePath, badge) %}
                <li>
                    <a href="{{ basePath }}{{ href }}"
                        {% if ('/' ~ href) == currentRoute %}aria-current="page" class="active"{% endif %}>
                        {{ label }}
                        {% if badge %}<span class="badge badge-{{ badge | lower }}">{{ badge }}</span>{% endif %}
                    </a>
                </li>
            {% endmacro %}
            {% import _self as m %}
            <section class="sidebar-section">
                <ul role="list">
                    {{ m.navlink('examples', '📖 Overview', currentRoute, basePath) }}
                </ul>
            </section>
            <section class="sidebar-section">
                <h3 class="sidebar-heading">Beginner</h3>
                <ul role="list">
                    {{ m.navlink('examples/counter', '⚡ Counter', currentRoute, basePath) }}
                    {{ m.navlink('examples/greeter', '👋 Greeter', currentRoute, basePath) }}
                    {{ m.navlink('examples/path-params', '🔀 Path Parameters', currentRoute, basePath) }}
                    {{ m.navlink('examples/all-scopes', '🔭 All Scopes', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/live-search', '🔍 Live Search', currentRoute, basePath) }}
                </ul>
            </section>
            <section class="sidebar-section">
                <h3 class="sidebar-heading">Intermediate</h3>
                <ul role="list">
                    {{ m.navlink('examples/todo', '✓ Todo List', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/components', '🧩 Components', currentRoute, basePath) }}
                    {{ m.navlink('examples/client-monitor', '👁️ Client Monitor', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/shopping-cart', '🛒 Shopping Cart', currentRoute, basePath) }}
                    {{ m.navlink('examples/wizard', '🪄 Multi-step Form', currentRoute, basePath) }}
                    {{ m.navlink('examples/login', '🔐 Login Flow', currentRoute, basePath) }}
                    {{ m.navlink('examples/contact-form', '📬 Contact Form', currentRoute, basePath) }}
                </ul>
            </section>
            <section class="sidebar-section">
                <h3 class="sidebar-heading">Advanced</h3>
                <ul role="list">
                    {{ m.navlink('examples/stock-ticker', '📈 Stock Ticker', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/chat-room', '💬 Chat Room', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/game-of-life', '🎮 Game of Life', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/live-auction', '🔨 Live Auction', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/type-race', '⌨️ Type Race', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/spreadsheet', '📊 Spreadsheet', currentRoute, basePath, '👥') }}
                    {{ m.navlink('examples/theme-builder', '🎨 Theme Builder', currentRoute, basePath) }}
                    {{ m.navlink('examples/file-upload', '🧵 SharedWorker Upload', currentRoute, basePath) }}
                    {{ m.navlink('examples/mission-control', '🛰 NATS Visualizer', currentRoute, basePath, '👥') }}
                </ul>
            </section>
            <section class="sidebar-section">
                <h3 class="sidebar-heading">Debug</h3>
                <details class="signals-debug" data-ignore-morph>
                    <summary>Live signals</summary>
                    <pre data-json-signals class="signals-debug-pre"></pre>
                </details>
            </section>
        </nav>
    </aside>

    <main class="docs-content" id="content">
        <details class="mobile-subnav" data-ignore-morph>
            <summary>Examples menu</summary>
            <nav class="sidebar-nav">
                <ul role="list">
                    {{ m.navlink('examples/counter', '⚡ Counter', currentRoute, basePath) }}
                    {{ m.navlink('examples/greeter', '👋 Greeter', currentRoute, basePath) }}
                    {{ m.navlink('examples/path-params', '🔀 Path Parameters', currentRoute, basePath) }}
                    {{ m.navlink('examples/all-scopes', '🔭 All Scopes', currentRoute, basePath) }}
                    {{ m.navlink('examples/todo', '✓ Todo List', currentRoute, basePath) }}
                    {{ m.navlink('examples/components', '🧩 Components', currentRoute, basePath) }}
                    {{ m.navlink('examples/client-monitor', '👁️ Client Monitor', currentRoute, basePath) }}
                    {{ m.navlink('examples/stock-ticker', '📈 Stock Ticker', currentRoute, basePath) }}
                    {{ m.navlink('examples/chat-room', '💬 Chat Room', currentRoute, basePath) }}
                    {{ m.navlink('examples/game-of-life', '🎮 Game of Life', currentRoute, basePath) }}
                    {{ m.navlink('examples/live-auction', '🔨 Live Auction', currentRoute, basePath) }}
                    {{ m.navlink('examples/type-race', '⌨️ Type Race', currentRoute, basePath) }}
                    {{ m.navlink('examples/spreadsheet', '📊 Spreadsheet', currentRoute, basePath) }}
                    {{ m.navlink('examples/live-search', '🔍 Live Search', currentRoute, basePath) }}
                    {{ m.navlink('examples/shopping-cart', '🛒 Shopping Cart', currentRoute, basePath) }}
                    {{ m.navlink('examples/theme-builder', '🎨 Theme Builder', currentRoute, basePath) }}
                    {{ m.navlink('examples/wizard', '🪄 Multi-step Form', currentRoute, basePath) }}
                    {{ m.navlink('examples/login', '🔐 Login Flow', currentRoute, basePath) }}
                    {{ m.navlink('examples/mission-control', '🛰 NATS Visualizer', currentRoute, basePath, '👥') }}
                </ul>
            </nav>
        </details>
        {% block content %}{% endblock %}
    </main>

</div>
{% endblock %}
