{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
{# via:cut #}
<div id="content">
    {% if gameStatus.string == 'error' %}
        <div class="card doom-error">
            <strong>Error:</strong> {{ errorMessage.string }}
        </div>
    {% endif %}

    <div class="text-center mb-2">
        {% if gameStatus.string != 'running' %}
            <button data-on-click="{{ startGame.url }}" class="success">
                ▶ Start DOOM
            </button>
        {% else %}
            <button data-on-click="{{ stopGame.url }}" class="danger">
                ⏹ Stop DOOM
            </button>
        {% endif %}
    </div>

    {% if gameStatus.string == 'running' %}
        <div id="doom-viewport" tabindex="0" class="doom-viewport"
            data-on-keydown__prevent="{{ keyDown.url }}?key=$evt.key"
            data-on-keyup__prevent="{{ keyUp.url }}?key=$evt.key"
        >
            <img id="doom-frame"
                data-attr-src="{{ frameData.id }}"
                class="doom-frame"
                alt="DOOM"
            />
        </div>
        <p class="text-center text-xs text-muted mt-1">
            Click the viewport to capture keyboard. Arrow keys to move, Ctrl to fire, Space to open doors.
        </p>

        <div class="doom-stats">
            <div class="card stat-card">
                <div class="stat-value" data-text="{{ fps.id }}">{{ fps.value }}</div>
                <div class="stat-label">FPS</div>
            </div>
            <div class="card stat-card">
                <div class="stat-value" data-text="{{ frameCount.id }}">{{ frameCount.value }}</div>
                <div class="stat-label">Frames</div>
            </div>
            <div class="card stat-card">
                <div class="stat-value" data-text="{{ frameSize.id }}">{{ frameSize.value }}</div>
                <div class="stat-label">KB/frame</div>
            </div>
            <div class="card stat-card">
                <div class="stat-value" data-text="{{ cachedFrames.id }}">{{ cachedFrames.value }}</div>
                <div class="stat-label">Cached</div>
            </div>
        </div>
    {% else %}
        <div class="card doom-hero">
            <div class="doom-hero-icon">🎮</div>
            <h3>Server-Side DOOM</h3>
            <p class="text-muted">
                The game runs entirely on the server using a virtual framebuffer.<br>
                Frames are streamed to your browser via SSE.
            </p>
            <p class="text-xs text-muted">
                Requires: Xvfb, dsda-doom, scrot, xdotool, imagemagick
            </p>
        </div>
    {% endif %}
</div>
{# via:cut #}
{% endblock %}
