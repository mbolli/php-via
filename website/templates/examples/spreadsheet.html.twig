{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
{# via:cut #}
{% set vScrollRange = maxRow - viewportRows %}
{% set hScrollRange = maxCol - viewportCols %}
{% set vThumbPct = maxRow > 0 ? (viewportRows / maxRow * 100) : 100 %}
{% set vPosPct = vScrollRange > 0 ? (vr / vScrollRange * (100 - vThumbPct)) : 0 %}
{% set hThumbPct = maxCol > 0 ? (viewportCols / maxCol * 100) : 100 %}
{% set hPosPct = hScrollRange > 0 ? (vc / hScrollRange * (100 - hThumbPct)) : 0 %}
<div id="spreadsheet"
     tabindex="0"
     data-init="
        el.__lastRows = 0; el.__lastCols = 0;
        new ResizeObserver(() => el.dispatchEvent(new CustomEvent('ss-resize'))).observe(el);
        el.addEventListener('wheel', e => e.preventDefault(), { passive: false });
        el.__sbDrag = (cx, cy) => {
            if (!el.__drag) return;
            const axis = el.__drag;
            const track = axis === 'v' ? $ssTrackV : $ssTrackH;
            const thumb = axis === 'v' ? $ssThumbV : $ssThumbH;
            const rect = track.getBoundingClientRect();
            const ratio = axis === 'v'
                ? Math.max(0, Math.min(1, (cy - rect.top) / rect.height))
                : Math.max(0, Math.min(1, (cx - rect.left) / rect.width));
            const thumbPct = axis === 'v' ? {{ vThumbPct }} : {{ hThumbPct }};
            thumb.style.transition = 'none';
            if (axis === 'v') { thumb.style.top = (ratio * (100 - thumbPct)) + '%'; }
            else { thumb.style.left = (ratio * (100 - thumbPct)) + '%'; }
            const now = Date.now();
            if (now - (el.__lastScroll || 0) < 100) return;
            el.__lastScroll = now;
            if (axis === 'v') { ${{ scrollToRowId }} = Math.round(ratio * {{ maxRow - viewportRows }}); }
            else { ${{ scrollToColId }} = Math.round(ratio * {{ maxCol - viewportCols }}); }
            @get('{{ scrollToUrl }}');
        };
        el.__sbEnd = (cx, cy) => {
            if (!el.__drag) return;
            const axis = el.__drag;
            const track = axis === 'v' ? $ssTrackV : $ssTrackH;
            const thumb = axis === 'v' ? $ssThumbV : $ssThumbH;
            thumb.style.transition = '';
            if (cx != null) {
                const rect = track.getBoundingClientRect();
                const ratio = axis === 'v'
                    ? Math.max(0, Math.min(1, (cy - rect.top) / rect.height))
                    : Math.max(0, Math.min(1, (cx - rect.left) / rect.width));
                if (axis === 'v') { ${{ scrollToRowId }} = Math.round(ratio * {{ maxRow - viewportRows }}); }
                else { ${{ scrollToColId }} = Math.round(ratio * {{ maxCol - viewportCols }}); }
                @get('{{ scrollToUrl }}');
            }
            el.__drag = null; document.body.style.userSelect = '';
        };
     "
     data-on:ss-resize__throttle.200ms="
        const toolbarH = $ssToolbar?.offsetHeight ?? 36;
        const theadH = $ssThead?.offsetHeight ?? 28;
        const sbH = 14;
        const sbW = 14;
        const rows = Math.max(3, Math.min(100, Math.floor((el.clientHeight - toolbarH - theadH - sbH) / 28)));
        const cols = Math.max(3, Math.min(52, Math.floor((el.clientWidth - 36 - sbW) / 80)));
        if (rows !== el.__lastRows || cols !== el.__lastCols) {
            el.__lastRows = rows; el.__lastCols = cols;
            ${{ viewportRowsId }} = rows; ${{ viewportColsId }} = cols;
            @post('{{ resizeUrl }}');
        }
     "
     data-on:keydown__window="
        if (evt.target.matches?.('.ss-jump-input')) return;
        ${{ keyId }} = evt.key; ${{ shiftId }} = evt.shiftKey;
        const k = evt.key, e = ${{ editingId }};
        if (e) {
            if (['Tab','Enter','Escape'].includes(k)) {
                @get('{{ navigateUrl }}'); evt.preventDefault();
            }
            return;
        }
        if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(k)) {
            @get('{{ navigateUrl }}'); evt.preventDefault();
        } else if (['Tab','Enter','Escape','PageUp','PageDown','Home'].includes(k)) {
            @get('{{ navigateUrl }}'); evt.preventDefault();
        } else if (k === 'F2') {
            @get('{{ startEditUrl }}'); evt.preventDefault();
        } else if (k === 'c' && (evt.ctrlKey || evt.metaKey)) {
            @get('{{ getCopyDataUrl }}');
        } else if (k === 'Delete' || k === 'Backspace') {
            @get('{{ clearCellsUrl }}'); evt.preventDefault();
        } else if (k.length === 1 && !evt.ctrlKey && !evt.metaKey && !evt.altKey) {
            @get('{{ startEditUrl }}'); evt.preventDefault();
        }
     "
     data-on:keyup__window="${{ keyId }} = ''; ${{ shiftId }} = false"
     data-on:paste__window="${{ pastedId }} = event.clipboardData.getData('text/plain'); ${{ pastedId }} && @post('{{ pasteUrl }}'); event.preventDefault();"
     data-on:wheel__throttle.100ms__prevent="
        ${{ drId }} = evt.deltaY > 0 ? 4 : evt.deltaY < 0 ? -4 : 0;
        ${{ dcId }} = evt.deltaX > 0 ? 4 : evt.deltaX < 0 ? -4 : 0;
        if (${{ drId }} !== 0 || ${{ dcId }} !== 0) @get('{{ scrollUrl }}');
     "
     data-on:mousemove__window="el.__sbDrag(evt.clientX, evt.clientY)"
     data-on:touchmove__window="if (el.__drag) { evt.preventDefault(); const t = evt.touches[0]; el.__sbDrag(t.clientX, t.clientY); }"
     data-on:mouseup__window="el.__sbEnd(evt.clientX, evt.clientY)"
     data-on:touchend__window="el.__sbEnd(null, null)"
     >

    <div class="ss-toolbar" data-ref="ssToolbar">
        <div class="ss-cell-ref">
            {{ colNames[fc - vc] is defined ? colNames[fc - vc] : '' }}{{ fr + 1 }}
        </div>
        <label class="ss-jump-label" for="ss-jump-input">Jump to</label>
        <input type="text"
               id="ss-jump-input"
               class="ss-jump-input"
               data-bind="{{ jumpId }}"
               placeholder="B5"
               data-on:keydown="if (evt.key === 'Enter') { evt.preventDefault(); @get('{{ jumpUrl }}') }"
               data-on:blur="${{ jumpId }} !== '' && @get('{{ jumpUrl }}')"
        >
        <div class="ss-formula-bar">{{ focusedCellValue }}</div>
        <div class="ss-users">
            👥 {{ clientCount }} connected
        </div>
        <div class="ss-pos">
            Row {{ fr + 1 }}, Col {{ colNames[fc - vc] is defined ? colNames[fc - vc] : (fc + 1) }}
            · Viewing from {{ colNames[0] }}{{ vr + 1 }}
        </div>
    </div>

    <div class="ss-body">
        <div class="ss-grid-wrapper">
            <table class="ss-grid">
                <thead data-ref="ssThead">
                    <tr>
                        <th class="ss-row-header">&nbsp;</th>
                        {% for colName in colNames %}
                            <th class="ss-col-header{% if vc + loop.index0 >= selRange.c1 and vc + loop.index0 <= selRange.c2 and selRange.r1 >= 0 %} ss-sel-header{% endif %}">{{ colName }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for ri in 0..(viewportRows - 1) %}
                        {% set absRow = vr + ri %}
                        <tr>
                            <th class="ss-row-header{% if absRow >= selRange.r1 and absRow <= selRange.r2 and selRange.c1 >= 0 %} ss-sel-header{% endif %}">{{ absRow + 1 }}</th>
                            {% for ci in 0..(viewportCols - 1) %}
                                {% set absCol = vc + ci %}
                                {% set cellKey = absRow ~ ':' ~ absCol %}
                                {% set isFocused = absRow == fr and absCol == fc %}
                                {% set hasMultiSel = selRange.r1 >= 0 and (selRange.r1 != selRange.r2 or selRange.c1 != selRange.c2) %}
                                {% set isSelected = hasMultiSel and absRow >= selRange.r1 and absRow <= selRange.r2 and absCol >= selRange.c1 and absCol <= selRange.c2 %}
                                {% set otherHue = otherCursors[cellKey] is defined ? otherCursors[cellKey] : null %}
                                <td class="ss-cell{% if isFocused %} ss-focused{% endif %}{% if isSelected %} ss-selected{% endif %}{% if otherHue is not null %} ss-other-cursor{% endif %}"
                                    {% if isFocused %}style="outline: 2px solid hsl({{ myHue }}, 70%, 50%); outline-offset: -1px;"{% endif %}
                                    {% if otherHue is not null and not isFocused %}style="box-shadow: inset 0 0 0 2px hsl({{ otherHue }}, 70%, 50%);"{% endif %}
                                    {% if not isFocused %}
                                        data-on:click="${{ shiftId }} = evt.shiftKey; ${{ trId }} = {{ absRow }}; ${{ tcId }} = {{ absCol }}; @get('{{ focusCellUrl }}')"
                                    {% endif %}
                                    data-on:dblclick="@get('{{ startEditUrl }}')"
                                >
                                    {% if isFocused and isEditing %}
                                        <input type="text" data-init="el.focus()" id="ss-active-input" class="ss-edit-input" data-bind="{{ editValueId }}">
                                    {% else %}
                                        <span class="ss-cell-text">{{ cells[cellKey] is defined ? cells[cellKey] : '' }}</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="ss-scrollbar ss-scrollbar-v"
             data-on:mousedown__prevent="
                const rect = $ssTrackV.getBoundingClientRect();
                if (evt.target === $ssThumbV || $ssThumbV.contains(evt.target)) {
                    el.closest('#spreadsheet').__drag = 'v'; document.body.style.userSelect = 'none';
                } else {
                    ${{ scrollToRowId }} = Math.round(Math.max(0, Math.min(1, (evt.clientY - rect.top) / rect.height)) * {{ maxRow - viewportRows }});
                    @get('{{ scrollToUrl }}');
                }
             "
             data-on:touchstart__prevent="
                const rect = $ssTrackV.getBoundingClientRect(); const t = evt.touches[0];
                if (evt.target === $ssThumbV || $ssThumbV.contains(evt.target)) {
                    el.closest('#spreadsheet').__drag = 'v';
                } else {
                    ${{ scrollToRowId }} = Math.round(Math.max(0, Math.min(1, (t.clientY - rect.top) / rect.height)) * {{ maxRow - viewportRows }});
                    @get('{{ scrollToUrl }}');
                }
             ">
            <div class="ss-scrollbar-track" data-ref="ssTrackV">
                <div class="ss-scrollbar-thumb" data-ref="ssThumbV" style="top: {{ vPosPct }}%; height: {{ vThumbPct }}%"></div>
            </div>
        </div>
    </div>

    <div class="ss-scrollbar-bottom">
        <div class="ss-scrollbar ss-scrollbar-h"
             data-on:mousedown__prevent="
                const rect = $ssTrackH.getBoundingClientRect();
                if (evt.target === $ssThumbH || $ssThumbH.contains(evt.target)) {
                    el.closest('#spreadsheet').__drag = 'h'; document.body.style.userSelect = 'none';
                } else {
                    ${{ scrollToColId }} = Math.round(Math.max(0, Math.min(1, (evt.clientX - rect.left) / rect.width)) * {{ maxCol - viewportCols }});
                    @get('{{ scrollToUrl }}');
                }
             "
             data-on:touchstart__prevent="
                const rect = $ssTrackH.getBoundingClientRect(); const t = evt.touches[0];
                if (evt.target === $ssThumbH || $ssThumbH.contains(evt.target)) {
                    el.closest('#spreadsheet').__drag = 'h';
                } else {
                    ${{ scrollToColId }} = Math.round(Math.max(0, Math.min(1, (t.clientX - rect.left) / rect.width)) * {{ maxCol - viewportCols }});
                    @get('{{ scrollToUrl }}');
                }
             ">
            <div class="ss-scrollbar-track" data-ref="ssTrackH">
                <div class="ss-scrollbar-thumb" data-ref="ssThumbH" style="left: {{ hPosPct }}%; width: {{ hThumbPct }}%"></div>
            </div>
        </div>
        <div class="ss-scrollbar-corner"></div>
    </div>
</div>
{# via:cut #}
{% endblock %}

{% block head %}
<style>
    .ss-toolbar {
        display: flex;
        align-items: center;
        gap: var(--size-2);
        padding: var(--size-1) var(--size-2);
        background: var(--surface-2);
        border: 1px solid var(--surface-3);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        font-size: var(--font-size-0);
        flex-shrink: 0;
        flex-wrap: wrap;
    }
    .ss-cell-ref {
        font-weight: 700;
        min-width: 4ch;
        padding: var(--size-1) var(--size-2);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        border-radius: var(--radius-sm);
    }
    .ss-jump-label {
        font-size: var(--font-size-0);
        color: var(--text-2);
        white-space: nowrap;
    }
    #spreadsheet .ss-jump-input {
        width: 10ch;
        padding: var(--size-1) var(--size-2);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        border-radius: var(--radius-sm);
        font-size: var(--font-size-0);
        font-family: inherit;
        font-weight: 400;
        color: inherit;
        height: 100%;
        box-sizing: border-box;
        align-self: stretch;
    }
    #spreadsheet .ss-jump-input:focus {
        outline: 2px solid var(--blue-5);
        outline-offset: -1px;
    }
    .ss-users { color: var(--text-2); white-space: nowrap; }
    .ss-pos { color: var(--text-3); font-size: 0.75rem; white-space: nowrap; }
    .ss-formula-bar {
        flex: 1;
        min-width: 6rem;
        padding: 0 var(--size-2);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        border-radius: var(--radius-sm);
        font-size: var(--font-size-0);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--text-1);
        align-self: stretch;
        display: flex;
        align-items: center;
    }
    .ss-grid-wrapper {
        flex: 1;
        min-height: 0;
        overflow: hidden;
        border: 1px solid var(--surface-3);
        border-top: 0;
        border-radius: 0;
    }
    .ss-body {
        display: flex;
        flex: 1;
        min-height: 0;
    }
    .ss-body > .ss-grid-wrapper {
        flex: 1;
        min-width: 0;
    }
    /* ─── Scrollbars ──────────────────────── */
    .ss-scrollbar {
        background: var(--surface-2);
        border: 1px solid var(--surface-3);
        box-sizing: border-box;
    }
    .ss-scrollbar-v {
        width: 14px;
        border-top: 0;
        border-left: 0;
    }
    .ss-scrollbar-h {
        flex: 1;
        height: 14px;
        border-top: 0;
        border-radius: 0 0 0 var(--radius-md);
    }
    .ss-scrollbar-track {
        position: relative;
        width: 100%;
        height: 100%;
    }
    .ss-scrollbar-thumb {
        position: absolute;
        border-radius: 4px;
        background: var(--text-3);
        opacity: 0.45;
        transition: opacity 120ms ease, top 180ms ease, left 180ms ease;
        min-width: 16px;
        min-height: 16px;
    }
    .ss-scrollbar-thumb:hover,
    .ss-scrollbar-thumb:active {
        opacity: 0.7;
    }
    .ss-scrollbar-v .ss-scrollbar-thumb {
        left: 2px;
        right: 2px;
        width: auto;
    }
    .ss-scrollbar-h .ss-scrollbar-thumb {
        top: 2px;
        bottom: 2px;
        height: auto;
    }
    .ss-scrollbar-bottom {
        display: flex;
        flex-shrink: 0;
    }
    .ss-scrollbar-corner {
        width: 14px;
        height: 14px;
        background: var(--surface-2);
        border: 1px solid var(--surface-3);
        border-top: 0;
        border-left: 0;
        border-radius: 0 0 var(--radius-md) 0;
        flex-shrink: 0;
    }
    .ss-grid {
        border-collapse: collapse;
        background: transparent;
        width: 100%;
        table-layout: fixed;
        font-size: var(--font-size-0);
        user-select: none;
    }
    .ss-grid th, .ss-grid td {
        border: 1px solid var(--surface-3);
        padding: 0;
        height: 1.75rem;
        text-align: left;
        position: relative;
    }
    .ss-col-header, .ss-row-header {
        background: var(--surface-2);
        color: var(--text-2);
        text-align: center !important;
        font-weight: 500;
        font-size: 0.7rem;
        position: sticky;
        z-index: 1;
    }
    .ss-col-header {
        top: 0;
        min-width: 80px;
        width: 80px;
        border-start-end-radius: 0;
    }
    .ss-row-header {
        left: 0;
        width: 36px;
        min-width: 36px;
        border-start-start-radius: 0;
    }
    .ss-sel-header {
        background: var(--blue-2);
        color: var(--blue-9);
    }
    .ss-cell {
        cursor: cell;
        background: transparent;
        overflow: hidden;
        white-space: nowrap;
        max-width: 80px;
    }
    .ss-cell-text {
        display: block;
        padding: 0 var(--size-1);
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.75rem;
        white-space: nowrap;
    }
    #spreadsheet .ss-cell:hover .ss-cell-text:not(:empty) {
        position: absolute;
        top: -1px;
        left: -1px;
        overflow: visible;
        background: var(--surface-1);
        border: 1px solid var(--blue-5);
        border-radius: var(--radius-sm);
        box-shadow: 2px 2px 6px rgba(0,0,0,0.2);
        z-index: 10;
        width: max-content;
        max-width: min(400px, 80vw);
        padding-inline-end: var(--size-3);
        white-space: normal;
        padding-top: var(--size-1);
        padding-bottom: var(--size-1);
        line-height: 1.3;
    }
    #spreadsheet .ss-cell:hover:has(.ss-cell-text:not(:empty)) {
        overflow: visible;
        z-index: 10;
    }
    .ss-focused {
        z-index: 2;
    }
    .ss-selected {
        background: var(--surface-1) !important;
    }
    .ss-other-cursor {
        z-index: 1;
    }
    .ss-edit-input {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: none;
        outline: none;
        padding: 0 var(--size-1);
        font-size: inherit;
        font-family: inherit;
        background: var(--surface-1);
        z-index: 3;
    }
    .ss-paste-target {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        opacity: 0;
    }
    #spreadsheet {
        outline: none;
        position: relative;
        resize: both;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-width: 320px;
        min-height: 160px;
        max-width: 100%;
    }
    #spreadsheet:focus-visible {
        outline: none;
    }
    .demo-box {
        padding: 0;
        border: none;
        background: none;
        border-radius: 0;
    }
    @media (max-width: 520px) {
        .ss-formula-bar { display: none; }
        .ss-pos { display: none; }
        .ss-jump-label { display: none; }
        #spreadsheet { height: 70vh; }
    }
    @starting-style {
        #spreadsheet tbody tr { opacity: 0; transform: translateY(-4px); }
    }
    #spreadsheet tbody tr {
        transition: opacity 150ms ease, transform 150ms ease;
    }
</style>
{% endblock %}
