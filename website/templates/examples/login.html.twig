{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
<div id="login-demo">

{% if errorMsg.string != '' %}
<div class="login-error">✕ {{ errorMsg.string|e }}</div>
{% endif %}

<form class="login-form" onsubmit="return false">
    <h3 class="login-form-title">Sign in</h3>

    <div class="login-field">
        <label for="login-username">Username</label>
        <input id="login-username"
               type="text"
               autocomplete="username"
               placeholder="ada"
               data-bind="{{ usernameInput.id }}">
    </div>

    <div class="login-field">
        <label for="login-password">Password</label>
        <input id="login-password"
               type="password"
               autocomplete="current-password"
               placeholder="········"
               data-bind="{{ passwordInput.id }}">
    </div>

    <button class="login-submit-btn" data-on:click="@post('{{ login.url }}')">Log in</button>
</form>

<div class="login-credentials">
    <p class="login-credentials-label">Demo credentials</p>
    <table class="login-creds-table">
        <thead><tr><th>Username</th><th>Password</th><th>Role</th></tr></thead>
        <tbody>
        {% for u in users %}
        <tr>
            <td><code>{{ u.username }}</code></td>
            <td><code>{{ u.password }}</code></td>
            <td>{{ u.role }}</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="login-middleware-note">
    <p>💡 <strong>Try visiting <a href="/examples/login/dashboard">/examples/login/dashboard</a> directly</strong> —
    the <code>AuthMiddleware</code> will redirect you back here because you're not logged in yet.
    After logging in, you'll be sent to the protected dashboard automatically.</p>
</div>

</div>
{% endblock %}

{% block extra %}
<style>
#login-demo {
    max-width: 480px;
    margin: 0 auto;
}

/* ── Login form ── */
.login-error {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
    border-radius: .5rem;
    padding: .65rem .9rem;
    font-weight: 500;
    font-size: .9rem;
    margin-bottom: 1rem;
}

.login-form {
    display: flex;
    flex-direction: column;
    gap: .9rem;
    background: var(--surface-2, #f8fafc);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: .75rem;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
}

.login-form-title { margin: 0 0 .25rem; font-size: 1rem; font-weight: 600; }

.login-field {
    display: flex;
    flex-direction: column;
    gap: .3rem;
}

.login-field label {
    font-size: .875rem;
    font-weight: 500;
    color: var(--text-muted, #64748b);
}

.login-field input { width: 100%; box-sizing: border-box; }

.login-submit-btn { width: 100%; margin-top: .25rem; }

/* ── Demo credentials table ── */
.login-credentials { margin-top: .5rem; }

.login-credentials-label {
    font-size: .8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--text-muted, #94a3b8);
    margin: 0 0 .4rem;
}

.login-creds-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
}

.login-creds-table th,
.login-creds-table td {
    padding: .35rem .6rem;
    text-align: left;
    border-bottom: 1px solid var(--border, #e2e8f0);
}

.login-creds-table th {
    font-weight: 600;
    color: var(--text-muted, #64748b);
    background: var(--surface-2, #f8fafc);
}

/* ── Middleware note ── */
.login-middleware-note {
    font-size: .875rem;
    color: var(--text-muted, #64748b);
    background: var(--surface-2, #f8fafc);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: .5rem;
    padding: .75rem 1rem;
    margin-top: 1rem;
    max-inline-size: unset;
}
.login-middleware-note p { margin: 0; }
</style>
{% endblock %}
