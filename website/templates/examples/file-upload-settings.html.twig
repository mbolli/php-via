{% extends 'examples/_file-upload-wrapper.html.twig' %}

{% block fu_content %}
<div class="fu-settings">

    <h3 class="fu-settings-heading">Account Settings</h3>
    <p class="fu-settings-subhead">
        This is a placeholder page to demonstrate that uploads survive navigation.
        The progress bar above is still tracking your upload — driven by SESSION-scoped signals.
    </p>

    <form class="fu-settings-form" onsubmit="return false">
        <fieldset class="fu-fieldset">
            <legend>Profile</legend>
            <div class="fu-field">
                <label for="s-name">Display name</label>
                <input id="s-name" type="text" class="fu-input" value="Ada Lovelace" disabled>
            </div>
            <div class="fu-field">
                <label for="s-email">Email address</label>
                <input id="s-email" type="email" class="fu-input" value="ada@babbage.co.uk" disabled>
            </div>
        </fieldset>

        <fieldset class="fu-fieldset">
            <legend>Upload preferences</legend>
            <div class="fu-field">
                <label for="s-concurrent">Max concurrent uploads</label>
                <select id="s-concurrent" class="fu-select" disabled>
                    <option>1</option><option selected>2</option><option>4</option>
                </select>
            </div>
            <div class="fu-field">
                <label for="s-chunk">Chunk size</label>
                <select id="s-chunk" class="fu-select" disabled>
                    <option>256 KB</option><option selected>512 KB</option><option>1 MB</option>
                </select>
            </div>
            <div class="fu-field fu-field-checkbox">
                <input id="s-resume" type="checkbox" checked disabled>
                <label for="s-resume">Enable resumable uploads</label>
            </div>
        </fieldset>

        <div class="fu-settings-actions">
            <button class="fu-start-btn" disabled>Save changes</button>
            <button class="fu-start-btn secondary" disabled>Cancel</button>
        </div>
    </form>

    <div class="fu-settings-note">
        <strong>Server state, not browser state.</strong>
        If this were a real settings page, navigating here, changing a setting, and going
        back would not have interrupted the upload — because neither the worker nor the
        SESSION signals depend on which page you are viewing.
    </div>

</div>
{% endblock %}

{% block fu_extra %}
<style>
.fu-settings { max-width: 520px; }
.fu-settings-heading { font-size: 1.1rem; font-weight: 600; margin: 0 0 6px; }
.fu-settings-subhead { color: var(--text-2, #64748b); font-size: 0.9rem; margin-bottom: 24px; }
.fu-settings-form { display: flex; flex-direction: column; gap: 20px; }
.fu-fieldset {
    border: 1px solid var(--border, #e2e8f0); border-radius: 10px; padding: 16px 20px;
    display: flex; flex-direction: column; gap: 14px;
}
.fu-fieldset legend {
    font-size: 0.8rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.04em; color: var(--text-2, #94a3b8); padding: 0 6px;
}
.fu-field-checkbox { flex-direction: row; align-items: center; gap: 8px; }
.fu-field-checkbox label { font-weight: 400; }
.fu-settings-actions { display: flex; gap: 10px; }
.fu-start-btn { cursor: not-allowed; opacity: 0.45; }
.fu-settings-note {
    margin-top: 24px; padding: 12px 16px;
    background: var(--surface-2, #f0fdf4); border: 1px solid #bbf7d0;
    border-radius: 10px; font-size: 0.85rem; color: #166534; line-height: 1.5;
}
</style>
{% endblock %}
