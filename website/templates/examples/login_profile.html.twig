{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
<div id="login-demo">

<div class="login-card">
    <div class="login-avatar">{{ auth.name|slice(0,1)|upper }}</div>
    <div class="login-info">
        <div class="login-name">{{ auth.name|e }}</div>
        <div class="login-role">{{ auth.role|e }}</div>
        <div class="login-since">Session started {{ auth.at|date('H:i:s') }}</div>
    </div>
</div>

<div class="login-profile-fields">
    <div class="login-profile-row">
        <span class="login-profile-label">Username</span>
        <span class="login-profile-value">{{ auth.user|e }}</span>
    </div>
    <div class="login-profile-row">
        <span class="login-profile-label">Role</span>
        <span class="login-profile-value">{{ auth.role|e }}</span>
    </div>
    <div class="login-profile-row">
        <span class="login-profile-label">Logged in</span>
        <span class="login-profile-value">{{ auth.at|date('Y-m-d H:i:s') }}</span>
    </div>
</div>

<div class="login-middleware-note">
    <p>🛡️ <strong>Protected by the same <code>AuthMiddleware</code> as the dashboard</strong> —
    both routes sit inside a <code>Via::group()</code>, so a single <code>->middleware(new AuthMiddleware(...))</code>
    call covers both. No duplication.</p>
</div>

<div class="login-nav">
    <a href="/examples/login/dashboard" class="btn">← Dashboard</a>
    <button class="danger login-logout-btn" data-on:click="@post('{{ logout.url }}')">Log out</button>
</div>

</div>
{% endblock %}

{% block extra %}
<style>
#login-demo {
    max-width: 480px;
    margin: 0 auto;
}

.login-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--surface-2, #f8fafc);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: .75rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
}

.login-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: #6366f1;
    color: #fff;
    font-size: 1.4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.login-name { font-weight: 600; font-size: 1.05rem; }
.login-role { color: var(--text-muted, #64748b); font-size: .875rem; }
.login-since { color: var(--text-muted, #94a3b8); font-size: .8rem; margin-top: .2rem; }

.login-profile-fields {
    border: 1px solid var(--border, #e2e8f0);
    border-radius: .5rem;
    overflow: hidden;
    margin-bottom: 1rem;
}

.login-profile-row {
    display: flex;
    justify-content: space-between;
    padding: .6rem 1rem;
    font-size: .875rem;
    border-bottom: 1px solid var(--border, #e2e8f0);
}

.login-profile-row:last-child { border-bottom: none; }

.login-profile-label { color: var(--text-muted, #64748b); }
.login-profile-value { font-weight: 500; }

.login-middleware-note {
    font-size: .875rem;
    color: var(--text-muted, #64748b);
    background: var(--surface-2, #f8fafc);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: .5rem;
    padding: .75rem 1rem;
    margin-bottom: 1rem;
    max-inline-size: unset;
}
.login-middleware-note p { margin: 0; }

.login-nav {
    display: flex;
    gap: .75rem;
}

.login-nav .btn {
    flex: 1;
    text-align: center;
    padding: .5rem 1rem;
    border-radius: .5rem;
    background: var(--surface-2, #f0f4f8);
    text-decoration: none;
    font-weight: 500;
    font-size: .875rem;
    border: 1px solid var(--border, #e2e8f0);
    color: var(--text, inherit);
}

.login-logout-btn { flex: 1; }
</style>
{% endblock %}
