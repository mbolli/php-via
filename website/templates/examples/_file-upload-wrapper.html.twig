{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
<div id="file-upload-{{ activePage|default('upload') }}" class="fu-layout">

    {# ── Persistent progress bar ───────────────────────────────────────────── #}
    {% if status.string != 'idle' %}
    <div id="upload-progress-bar" class="upload-progress-bar">
        <div class="upload-progress-inner">
            <div class="upload-track" aria-label="Upload progress" role="progressbar"
                 aria-valuenow="{{ pct.int }}" aria-valuemin="0" aria-valuemax="100">
                <div id="upload-fill" class="upload-fill" style="width: {{ pct.int }}%"></div>
                {% if status.string == 'uploading' %}<div class="upload-shimmer"></div>{% endif %}
            </div>

            <div class="upload-info">
                <span class="upload-icon">
                    {% if status.string == 'uploading' %}📤{% endif %}
                    {% if status.string == 'complete' %}✅{% endif %}
                    {% if status.string == 'cancelled' %}🚫{% endif %}
                </span>

                <span id="upload-filename" class="upload-filename">{{ fileName.string }}</span>

                <span class="upload-pct-wrap">
                    <span id="upload-pct" class="upload-pct">{{ pct.int }}%</span>
                    <span class="upload-status-label"> {{ status.string }}</span>
                </span>

                {% if status.string == 'uploading' %}
                <button class="upload-cancel-btn" id="upload-cancel-btn" title="Cancel upload"
                        onclick="uploadCancelAction('{{ cancelUpload.url }}', '{{ ctxId }}')">✕</button>
                {% endif %}
                {% if status.string == 'complete' or status.string == 'cancelled' %}
                <button class="upload-reset-btn" id="upload-reset-btn"
                        onclick="uploadCancelAction('{{ cancelUpload.url }}', '{{ ctxId }}')">↺ Reset</button>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ── Sub-page nav ──────────────────────────────────────────────────────── #}
    <nav class="fu-subnav" aria-label="Upload example sub-pages">
        <a href="{{ basePath }}examples/file-upload"
           class="fu-subnav-link{{ activePage == 'upload' ? ' active' : '' }}"
           {{ activePage == 'upload' ? 'aria-current="page"' : '' }}>⬆ Upload</a>
        <a href="{{ basePath }}examples/file-upload/browse"
           class="fu-subnav-link{{ activePage == 'browse' ? ' active' : '' }}"
           {{ activePage == 'browse' ? 'aria-current="page"' : '' }}>📁 Browse</a>
        <a href="{{ basePath }}examples/file-upload/settings"
           class="fu-subnav-link{{ activePage == 'settings' ? ' active' : '' }}"
           {{ activePage == 'settings' ? 'aria-current="page"' : '' }}>⚙ Settings</a>
    </nav>

    {# Confirm dialog shown when navigating during a real upload on browsers without extendedLifetime. #}
    {# JS shows/hides it; kept in {% block demo %} so Datastar morphing can find the element. #}
    <div id="fu-nav-confirm" class="fu-nav-confirm" style="display:none" role="alertdialog"
         aria-labelledby="fu-nav-confirm-msg">
        <span id="fu-nav-confirm-msg">⚠️ Navigating will cancel the upload in progress.</span>
        <button id="fu-nav-confirm-ok"   class="fu-nav-confirm-btn fu-nav-confirm-ok">Cancel upload &amp; navigate</button>
        <button id="fu-nav-confirm-stay" class="fu-nav-confirm-btn">Stay</button>
    </div>

    {# ── Per-sub-page content ──────────────────────────────────────────────── #}
    <div class="fu-content">
        {% block fu_content %}{% endblock %}
    </div>

</div>{# #file-upload-{activePage} #}

{% endblock %}

{% block extra %}

{# ── Shared styles ─────────────────────────────────────────────────────────── #}
<style>
/* Progress bar */
.upload-progress-bar {
    border-radius: 12px;
    background: var(--surface-2, #f1f5f9);
    border: 1px solid var(--border, #e2e8f0);
    padding: 12px 16px;
    margin-bottom: 20px;
    transition: opacity 0.3s;
}
.upload-progress-inner { display: flex; flex-direction: column; gap: 8px; }
.upload-track {
    position: relative;
    height: 8px;
    background: var(--border, #e2e8f0);
    border-radius: 9999px;
    overflow: hidden;
}
.upload-fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #6366f1);
    border-radius: 9999px;
    transition: width 0.15s ease-out;
    min-width: 4px;
}
.upload-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer 1.8s linear infinite;
}
@keyframes shimmer { from { background-position: 200% 0; } to { background-position: -200% 0; } }
.upload-info { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--text-2, #64748b); }
.upload-filename {
    flex: 1;
    font-weight: 500;
    color: var(--text-1, #1e293b);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
}
.upload-pct { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--brand, #3b82f6); }
.upload-status-label { color: var(--text-2, #94a3b8); font-size: 0.8rem; }
.upload-cancel-btn, .upload-reset-btn {
    background: none;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 0.8rem;
    cursor: pointer;
    color: var(--text-2, #64748b);
    line-height: 1.6;
    transition: background 0.15s;
}
.upload-cancel-btn:hover { background: #fee2e2; color: #dc2626; border-color: #fca5a5; }
.upload-reset-btn:hover  { background: #e0e7ff; color: #4f46e5; border-color: #a5b4fc; }

/* Layout */
.fu-layout { display: flex; flex-direction: column; gap: 0; }

/* Sub-page nav */
.fu-subnav {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border, #e2e8f0);
    padding-bottom: 0;
    margin-bottom: 24px;
}
.fu-subnav-link {
    padding: 8px 16px;
    border-radius: 8px 8px 0 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-2, #64748b);
    text-decoration: none;
    border: 1px solid transparent;
    border-bottom: none;
    transition: background 0.15s, color 0.15s;
    position: relative;
    bottom: -1px;
}
.fu-subnav-link:hover { background: var(--surface-2, #f1f5f9); color: var(--text-1, #1e293b); }
.fu-subnav-link.active {
    background: var(--surface-1, #fff);
    color: var(--brand, #3b82f6);
    border-color: var(--border, #e2e8f0);
    border-bottom-color: var(--surface-1, #fff);
}
/* Confirm-before-navigate dialog shown during real uploads on browsers without extendedLifetime */
.fu-nav-confirm {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    border-radius: 6px;
    padding: 8px 12px;
    margin-bottom: 16px;
}
.fu-nav-confirm-btn {
    padding: 3px 12px;
    border-radius: 5px;
    border: 1px solid #d97706;
    background: #fff;
    color: #92400e;
    font-size: 0.8rem;
    cursor: pointer;
    white-space: nowrap;
}
.fu-nav-confirm-btn:hover { background: #fde68a; }
.fu-nav-confirm-ok { border-color: #ef4444; color: #dc2626; }
.fu-nav-confirm-ok:hover { background: #fee2e2; }

/* Shared form/button primitives used across sub-pages */
.fu-field { display: flex; flex-direction: column; gap: 5px; }
.fu-field label { font-size: 0.875rem; font-weight: 500; }
.fu-input, .fu-select {
    padding: 8px 12px;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 8px;
    font-size: 0.9rem;
    background: var(--surface-1, #fff);
    color: var(--text-1, #1e293b);
}
.fu-select { cursor: pointer; }
.fu-start-btn {
    padding: 10px 24px;
    background: var(--brand, #3b82f6);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    align-self: flex-start;
    transition: background 0.15s;
}
.fu-start-btn:hover { background: #2563eb; }
.fu-start-btn.secondary {
    background: none;
    border: 1px solid var(--border, #e2e8f0);
    color: var(--text-1, #1e293b);
}
.fu-start-btn.secondary:hover { background: var(--surface-2, #f1f5f9); }
/* Reset Open Props prose constraints inside demo blocks */
.example-demo h3, .example-demo p { max-inline-size: unset; }
</style>

{# ── Shared JS: utility functions + SharedWorker init ─────────────────────── #}
<script>
'use strict';

var _FU = {
    chunkUrl:       '{{ receiveChunk.url }}',
    uploadChunkUrl: '{{ uploadChunk.url }}',
    cancelUrl:      '{{ cancelUpload.url }}',
    ctxId:          '{{ ctxId }}',
};

function uploadCancelAction(url, ctxId) {
    if (window.uploadWorkerPort) {
        window.uploadWorkerPort.postMessage({ type: 'cancel' });
    }
    fetch(url, {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:    new URLSearchParams({ via_ctx: ctxId }),
    });
}

function applyWorkerState(s) {
    var fill   = document.getElementById('upload-fill');
    var pctEl  = document.getElementById('upload-pct');
    var nameEl = document.getElementById('upload-filename');
    if (fill)              fill.style.width   = s.pct + '%';
    if (pctEl)             pctEl.textContent  = s.pct + '%';
    if (nameEl && s.fileName) nameEl.textContent = s.fileName;

    // Persist uploading state so a new worker instance can resume after GC
    // during MPA navigation. Real uploads are not persisted — File is not serialisable.
    try {
        if (s.status === 'uploading' && !s.isReal) {
            sessionStorage.setItem('_fu_state', JSON.stringify(s));
        } else if (s.status === 'complete' || s.status === 'cancelled') {
            sessionStorage.removeItem('_fu_state');
        }
    } catch {}

    // Guard: show confirm dialog on subnav when a real upload is in progress
    // and extendedLifetime did NOT keep the worker alive (detected first time by
    // workerBorn comparison; undefined = first load, show it conservatively).
    var confirm = document.getElementById('fu-nav-confirm');
    if (confirm) {
        confirm.style.display = (s.status === 'uploading' && s.isReal && !window._fuExtended) ? '' : 'none';
    }
}

(function () {
    if (!('SharedWorker' in window)) {
        console.warn('SharedWorker not supported — upload continuity across navigation unavailable.');
        return;
    }
    // extendedLifetime: true — shipped in Chrome 148 (stable, no flag needed).
    // Keeps the worker alive for up to 30 s after the last port disconnects so it
    // survives MPA navigation gaps. Silently ignored on unsupported browsers.
    var worker = new SharedWorker(
        '{{ basePath }}upload-worker.js?v={{ workerVersion }}',
        { extendedLifetime: true }
    );
    window.uploadWorkerPort = worker.port;
    worker.port.start();
    worker.port.postMessage({
        type:           'connect',
        chunkUrl:       _FU.chunkUrl,
        uploadChunkUrl: _FU.uploadChunkUrl,
        cancelUrl:      _FU.cancelUrl,
        ctxId:          _FU.ctxId,
    });

    // On the first state message: detect if the worker survived the last navigation
    // (workerBorn unchanged → extendedLifetime is working, no need for nav guard).
    // Then check sessionStorage for a sim-upload to resume.
    var resumeChecked = false;
    worker.port.addEventListener('message', function (e) {
        if (e.data.type === 'log') {
            console.log(e.data.msg);
            return;
        }
        if (!resumeChecked) {
            resumeChecked = true;
            try {
                var prevBorn = sessionStorage.getItem('_fu_worker_born');
                if (prevBorn && e.data.workerBorn && String(e.data.workerBorn) === prevBorn) {
                    // Same worker instance — extendedLifetime is active; nav guard not needed.
                    window._fuExtended = true;
                    console.log('[upload-worker] worker survived navigation (extendedLifetime active)');
                }
                if (e.data.workerBorn) sessionStorage.setItem('_fu_worker_born', String(e.data.workerBorn));
            } catch {}

            if (e.data.status === 'idle') {
                try {
                    var saved = JSON.parse(sessionStorage.getItem('_fu_state') || 'null');
                    if (saved && saved.pct < 100) {
                        console.log('[upload-worker] worker was GC\'d — resuming from sessionStorage pct=' + saved.pct + '%');
                        worker.port.postMessage(Object.assign({}, saved, {
                            type:      'resume',
                            chunkUrl:  _FU.chunkUrl,
                            cancelUrl: _FU.cancelUrl,
                            ctxId:     _FU.ctxId,
                        }));
                    }
                } catch {}
            }
        }
        applyWorkerState(e.data);
    });

    // ── Navigation guard for real uploads ──────────────────────────────────────────
    // beforeunload: safety net for back button / address bar / external links
    window.addEventListener('beforeunload', function (e) {
        if (window._fuRealUploading && !window._fuExtended) {
            e.preventDefault();
            return (e.returnValue = '');
        }
    });

    // Subnav links: show in-page confirm so user can cancel cleanly
    document.addEventListener('click', function (e) {
        var link = e.target.closest('.fu-subnav-link');
        if (!link || !window._fuRealUploading || window._fuExtended) return;
        var href = link.href;
        e.preventDefault();
        var confirmEl = document.getElementById('fu-nav-confirm');
        var okBtn     = document.getElementById('fu-nav-confirm-ok');
        var stayBtn   = document.getElementById('fu-nav-confirm-stay');
        if (!confirmEl) return;
        confirmEl.style.display = '';
        var cleanup = function () {
            okBtn.removeEventListener('click', doNavigate);
            stayBtn.removeEventListener('click', doStay);
        };
        var doNavigate = function () {
            cleanup();
            uploadCancelAction(_FU.cancelUrl, _FU.ctxId);
            window._fuRealUploading = false;
            window.location.href = href;
        };
        var doStay = function () {
            cleanup();
            confirmEl.style.display = 'none';
        };
        okBtn.addEventListener('click', doNavigate);
        stayBtn.addEventListener('click', doStay);
    });

    // Track real-upload state for the guards above
    worker.port.addEventListener('message', function (e) {
        if (e.data.type !== 'log') {
            window._fuRealUploading = e.data.status === 'uploading' && e.data.isReal;
        }
    });
}());
</script>

{# ── Per-sub-page CSS / JS slot ────────────────────────────────────────────── #}
{% block fu_extra %}{% endblock %}

{% endblock %}{# extra #}
