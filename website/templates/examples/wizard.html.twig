{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
<div id="wizard">
    <div class="wizard-progress-bar-wrap">
        <div class="wizard-progress-bar" style="width: {{ (step.int / 3 * 100)|round }}%"></div>
    </div>
    <div class="wizard-steps-label">
        <span class="{{ step.int >= 1 ? 'active' : '' }}">1 Basics</span>
        <span class="{{ step.int >= 2 ? 'active' : '' }}">2 Stack</span>
        <span class="{{ step.int >= 3 ? 'active' : '' }}">3 Preview</span>
    </div>

    {% if error.string != '' %}
    <div class="wizard-error">{{ error.string|e }}</div>
    {% endif %}

    {% if step.int == 1 %}
    <div class="wizard-step">
        <h3 class="wizard-step-title">Step 1: The Basics</h3>

        <div class="wizard-field">
            <label for="wizard-name">Your name</label>
            <input id="wizard-name"
                   type="text"
                   placeholder="Ada Lovelace"
                   autocomplete="off"
                   data-bind="{{ name.id }}">
        </div>

        <div class="wizard-field">
            <label for="wizard-role">Role</label>
            <select id="wizard-role" data-bind="{{ role.id }}">
                {% for r in roles %}
                <option value="{{ r }}"{% if role.string == r %} selected{% endif %}>{{ r }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="wizard-field">
            <label for="wizard-years">Years of experience: <strong data-text="${{ years.id }}">{{ years.int }}</strong></label>
            <input id="wizard-years"
                   type="range"
                   min="0" max="30" step="1"
                   data-bind="{{ years.id }}">
        </div>
    </div>

    {% elseif step.int == 2 %}
    <div class="wizard-step">
        <h3 class="wizard-step-title">Step 2: Your Stack</h3>

        <div class="wizard-field">
            <label>Technologies you work with</label>
            <div class="stack-grid">
                {% for opt in stackOptions %}
                <label class="stack-option">
                    <input type="checkbox" data-bind="{{ stack[opt.key].id }}">
                    <span>{{ opt.label }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="wizard-field">
            <label for="wizard-editor">Favourite editor</label>
            <select id="wizard-editor" data-bind="{{ editor.id }}">
                {% for e in editors %}
                <option value="{{ e }}"{% if editor.string == e %} selected{% endif %}>{{ e }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    {% else %}
    <div class="wizard-step">
        <h3 class="wizard-step-title">Step 3: Your Dev Identity Card</h3>
        <div class="dev-card">
            <div class="dev-card-header">
                <div class="dev-card-avatar">{{ name.string|slice(0,1)|upper|default('?') }}</div>
                <div>
                    <div class="dev-card-name">{{ name.string|e }}</div>
                    <div class="dev-card-role badge">{{ role.string|e }}</div>
                </div>
            </div>
            <div class="dev-card-body">
                <div class="dev-card-row">
                    <span class="dev-card-icon">📅</span>
                    {{ years.int }} year{{ years.int != 1 ? 's' : '' }} of experience
                </div>
                <div class="dev-card-row">
                    <span class="dev-card-icon">🔧</span>
                    {% if selectedStack|length > 0 %}
                        {{ selectedStack|join(', ') }}
                    {% else %}
                        <em style="opacity:.6">No stack selected</em>
                    {% endif %}
                </div>
                <div class="dev-card-row">
                    <span class="dev-card-icon">💻</span>
                    {{ editor.string|e }}
                </div>
            </div>
            <div class="dev-card-footer">
                <small>Generated by php-via · {{ "now"|date("Y-m-d") }}</small>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="wizard-nav">
        {% if step.int > 1 %}
        <button class="secondary" data-on:click="@post('{{ back.url }}')">← Back</button>
        {% else %}
        <span></span>
        {% endif %}

        {% if step.int < 3 %}
        <button data-on:click="@post('{{ next.url }}')">Next →</button>
        {% else %}
        <button class="secondary" data-on:click="@post('{{ restart.url }}')">↺ Start over</button>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block extra %}
<style>
#wizard { max-width: 520px; margin: 0 auto; }
.wizard-progress-bar-wrap {
    height: 4px;
    background: var(--border, #e2e8f0);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: .6rem;
}
.wizard-progress-bar {
    height: 100%;
    background: var(--brand, #6366f1);
    border-radius: 2px;
    transition: width .4s ease;
}
.wizard-steps-label {
    display: flex;
    justify-content: space-between;
    font-size: .75rem;
    color: var(--text-muted, #64748b);
    margin-bottom: 1.25rem;
}
.wizard-steps-label span.active { color: var(--brand, #6366f1); font-weight: 600; }
.wizard-error {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #dc2626;
    border-radius: .375rem;
    padding: .5rem .75rem;
    font-size: .875rem;
    margin-bottom: .75rem;
}
.wizard-step-title { font-size: 1rem; font-weight: 600; margin: 0 0 1rem; }
.wizard-field { margin-bottom: 1rem; display: flex; flex-direction: column; gap: .3rem; }
.wizard-field label { font-size: .875rem; font-weight: 500; }
.wizard-field input[type="text"],
.wizard-field select { width: 100%; }
.wizard-field input[type="range"] { width: 100%; accent-color: var(--brand, #6366f1); }

.stack-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .4rem;
}
.stack-option {
    display: flex;
    align-items: center;
    gap: .35rem;
    font-size: .85rem;
    cursor: pointer;
    padding: .3rem .5rem;
    border-radius: .3rem;
    border: 1px solid var(--border, #e2e8f0);
    background: var(--surface-2, #f8fafc);
}
.stack-option input { accent-color: var(--brand, #6366f1); cursor: pointer; }

.wizard-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--border, #e2e8f0);
    margin-top: 1rem;
}

/* Dev Identity Card */
.dev-card {
    border: 2px solid var(--brand, #6366f1);
    border-radius: .75rem;
    overflow: hidden;
    background: var(--surface-2, #f8fafc);
}
.dev-card-header {
    background: var(--brand, #6366f1);
    color: #fff;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: .85rem;
}
.dev-card-avatar {
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255,255,255,.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
}
.dev-card-name { font-size: 1rem; font-weight: 600; }
.dev-card-role { font-size: .75rem; margin-top: .15rem; background: rgba(255,255,255,.2); color: #fff; }
.dev-card-body { padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: .5rem; }
.dev-card-row  { display: flex; align-items: center; gap: .5rem; font-size: .9rem; }
.dev-card-icon { font-size: 1rem; flex-shrink: 0; }
.dev-card-footer {
    padding: .5rem 1.25rem;
    border-top: 1px solid var(--border, #e2e8f0);
    color: var(--text-muted, #64748b);
    text-align: right;
}
</style>
{% endblock %}
