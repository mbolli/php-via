{% extends 'shells/examples.html.twig' %}

{% block title %}{{ title }} — php-via Examples{% endblock %}

{% block content %}
<div class="example-page-header">
    <h1>{{ title }}</h1>
    <p>{{ description|raw }}</p>
    {% if summary is defined and summary %}
    <div class="example-summary">
        {% for paragraph in summary %}
        <div class="example-summary-col">{{ paragraph|raw }}</div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<div class="example-demo demo-box">
    {% block demo %}{% endblock %}
</div>

{% if anatomy is defined and anatomy %}
<div class="example-anatomy">
    {% if githubLinks is defined and githubLinks %}
    <div class="anatomy-github">
        <span class="anatomy-github-label">Source</span>
        {% for link in githubLinks %}
        <a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }} <span class="anatomy-github-ext">.{{ link.url|split('.')|last }}</span> →</a>
        {% endfor %}
    </div>
    {% endif %}

    <div class="anatomy-columns">
        {% if anatomy.signals is defined and anatomy.signals|length > 0 %}
        <div class="anatomy-section">
            <h3 class="anatomy-heading">⚡ Signals</h3>
            {% for signal in anatomy.signals %}
            <div class="anatomy-item">
                <div class="anatomy-item-header">
                    <code class="anatomy-name">{{ signal.name }}</code>
                    {% if signal.type is defined %}<span class="anatomy-badge anatomy-badge--type">{{ signal.type }}</span>{% endif %}
                    {% if signal.scope is defined %}<span class="anatomy-badge anatomy-badge--{{ signal.scope|lower|replace({':': '-', ' ': '-'}) }}">{{ signal.scope }}</span>{% endif %}
                    {% if signal.default is defined %}<span class="anatomy-badge anatomy-badge--default">{{ signal.default }}</span>{% endif %}
                </div>
                {% if signal.desc is defined %}<p class="anatomy-desc">{{ signal.desc }}</p>{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if anatomy.actions is defined and anatomy.actions|length > 0 %}
        <div class="anatomy-section">
            <h3 class="anatomy-heading">🎯 Actions</h3>
            {% for action in anatomy.actions %}
            <div class="anatomy-item">
                <div class="anatomy-item-header">
                    <code class="anatomy-name">{{ action.name }}</code>
                    {% if action.scope is defined %}<span class="anatomy-badge anatomy-badge--{{ action.scope|lower|replace({':': '-', ' ': '-'}) }}">{{ action.scope }}</span>{% endif %}
                </div>
                {% if action.desc is defined %}<p class="anatomy-desc">{{ action.desc }}</p>{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if anatomy.views is defined and anatomy.views|length > 0 %}
        <div class="anatomy-section">
            <h3 class="anatomy-heading">👁 Views</h3>
            {% for view in anatomy.views %}
            <div class="anatomy-item">
                <div class="anatomy-item-header">
                    <code class="anatomy-name">{{ view.name }}</code>
                </div>
                {% if view.desc is defined %}<p class="anatomy-desc">{{ view.desc }}</p>{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if anatomy.middleware is defined and anatomy.middleware|length > 0 %}
        <div class="anatomy-section">
            <h3 class="anatomy-heading">🛡️ Middleware</h3>
            {% for mw in anatomy.middleware %}
            <div class="anatomy-item">
                <div class="anatomy-item-header">
                    <code class="anatomy-name">{{ mw.name }}</code>
                </div>
                {% if mw.desc is defined %}<p class="anatomy-desc">{{ mw.desc }}</p>{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endif %}

{% block extra %}{% endblock %}
{% endblock %}
