{% extends 'examples/_wrapper.html.twig' %}

{% block demo %}
<div id="mc-root">

{# ── Status bar ──────────────────────────────────────────────────────────── #}
<div class="mc-status-bar">
    <span class="mc-status-dot {{ connected ? 'is-connected' : 'is-disconnected' }}"></span>
    <span class="mc-status-label">NATS {{ connected ? 'Connected' : 'Connecting…' }}</span>
    <span class="mc-status-stat">{{ streamCount }} events logged</span>
</div>

{# ── Flow diagram ─────────────────────────────────────────────────────────── #}
<div class="mc-flow" aria-hidden="true">
    <div class="mc-flow-left">
        <div class="mc-flow-box">
            <span class="mc-flow-box-title">Services</span>
            {% for key, svc in services %}
            <span class="mc-flow-svc {{ svc.isEmitting ? 'is-emitting' : '' }}" style="--svc-color:{{ svc.color }}">{{ svc.emoji }}</span>
            {% endfor %}
        </div>

        <div class="mc-flow-pipe {{ anyEmitting ? 'is-hot' : '' }}">
            <div class="mc-pipe-track"></div>
            <span class="mc-pipe-label">via.events.*</span>
        </div>
    </div>

    <div class="mc-flow-box mc-flow-box--nats">
        <span class="mc-flow-box-title">NATS</span>
        <span class="mc-flow-nats-badges">
            <span class="mc-nats-badge mc-nats-badge--core">Core</span>
            <span class="mc-nats-badge mc-nats-badge--js">JS</span>
            <span class="mc-nats-badge mc-nats-badge--kv">KV</span>
        </span>
    </div>

    {# Fan-out: NATS → two consumers stacked #}
    <div class="mc-flow-fanout">
        <div class="mc-flow-fanout-branch">
            <div class="mc-flow-pipe {{ anyEmitting ? 'is-hot' : '' }}">
                <div class="mc-pipe-track"></div>
                <span class="mc-pipe-label">sub #1 SSE</span>
            </div>
            <div class="mc-flow-box">
                <span class="mc-flow-box-title">Browser</span>
                <span style="font-size:1.5rem">🌐</span>
            </div>
        </div>
        <div class="mc-flow-fanout-branch mc-flow-fanout-branch--audit">
            <div class="mc-flow-pipe {{ anyEmitting ? 'is-hot' : '' }}">
                <div class="mc-pipe-track"></div>
                <span class="mc-pipe-label">sub #2</span>
            </div>
            <div class="mc-flow-box">
                <span class="mc-flow-box-title">Audit Logger</span>
                <span style="font-size:1.5rem">📝</span>
                <span style="font-size:.65rem;color:var(--text-2)">{{ auditTotal }} events</span>
            </div>
        </div>
    </div>
</div>

{# ── Three-column panels ──────────────────────────────────────────────────── #}
<div class="mc-panels">

    {# Left: Service cards #}
    <div class="mc-panel">
        <div class="mc-panel-title">Services</div>
        {% for key, svc in services %}
        <div class="mc-service-card {{ svc.isEmitting ? 'is-emitting' : '' }} {{ svc.killed ? (svc.guaranteed ? 'is-buffering' : 'is-dead') : '' }}"
             style="--svc-color:{{ svc.color }}">
            <div class="mc-service-dot">
                {{ svc.emoji }}
                {% if svc.isEmitting %}
                <span class="mc-emit-ring" id="ring-{{ key }}-{{ svc.emitId }}"></span>
                {% endif %}
            </div>
            <div class="mc-service-info">
                <div class="mc-service-label">
                    {{ svc.label }}
                    <span class="mc-delivery-badge"
                          title="{{ svc.guaranteed ? 'JetStream durable — guaranteed delivery: events buffer while consumer is paused' : 'Core pub/sub — best-effort: events are lost if the service is killed' }}">
                        {{ svc.guaranteed ? '🔒' : '📡' }}
                    </span>
                </div>
                <div class="mc-service-last">
                    {%- if svc.killed and svc.guaranteed -%}
                    <em class="mc-buffering-label">buffering…</em>
                    {%- else -%}
                    {{ svc.lastType ?: '— waiting —' }}
                    {%- endif -%}
                </div>
                <div class="mc-service-count">{{ svc.count }} events</div>
            </div>
            {% if not svc.killed %}
            <button class="mc-kill-btn" data-on:click="@post('{{ svc.killUrl }}')" title="{{ svc.guaranteed ? 'Pause consumer — events buffer in JetStream' : 'Stop service — events will be lost' }}">⏸</button>
            {% else %}
            <button class="mc-revive-btn" data-on:click="@post('{{ svc.reviveUrl }}')" title="{{ svc.guaranteed ? 'Resume — catch up buffered events' : 'Restart service' }}">▶</button>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    {# Centre: NATS topology #}
    <div class="mc-panel mc-panel--nats">
        <div class="mc-panel-title">NATS</div>
        <div class="mc-nats-row">
            <span class="mc-nats-badge mc-nats-badge--core">Core</span>
            <code>via.events.*</code>
            <span class="mc-nats-row-desc">auth, inventory</span>
        </div>
        <div class="mc-nats-row">
            <span class="mc-nats-badge mc-nats-badge--js">JetStream</span>
            <code>VIAEVENTS</code>
            <span class="mc-nats-row-desc">{{ streamCount }} msgs</span>
        </div>
        <div class="mc-nats-row">
            <span class="mc-nats-badge mc-nats-badge--js">Durable</span>
            <code>ui-orders, ui-payments</code>
            <span class="mc-nats-row-desc">ACK guaranteed</span>
        </div>
        <div class="mc-nats-row">
            <span class="mc-nats-badge mc-nats-badge--kv">KV</span>
            <code>viahealth</code>
            <span class="mc-nats-row-desc">heartbeats</span>
        </div>
        <div class="mc-nats-row">
            <span class="mc-nats-badge mc-nats-badge--core">Audit</span>
            <code>via.events.*</code>
            <span class="mc-nats-row-desc">{{ auditTotal }} ✓</span>
        </div>

        <div class="mc-health-label">Health (KV age)</div>
        <div class="mc-health-grid">
            {% for key, tile in health %}
            <div class="mc-health-tile is-{{ tile.status }}" id="ht-{{ key }}">
                <div class="mc-health-face mc-health-face--front">
                    <span class="mc-health-emoji">{{ tile.emoji }}</span>
                    <span class="mc-health-lbl">{{ tile.label }}</span>
                    <span class="mc-health-age">{{ tile.age is not null ? tile.age ~ 's' : '—' }}</span>
                </div>
                <div class="mc-health-face mc-health-face--back">
                    <span class="mc-health-emoji">{{ tile.emoji }}</span>
                    <span class="mc-health-down-label">DOWN</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {# Right: Live event stream #}
    <div class="mc-panel mc-panel--stream">
        <div class="mc-panel-title">Event Stream</div>
        <div class="mc-events">
            {% for event in events %}
            <div class="mc-event {{ loop.first and not event.isReplay ? 'is-new' : '' }} {{ event.isReplay ? 'is-replay' : '' }} mc-svc-{{ event.service }}"
                 id="evt-{{ event.id }}"
                 {% if event.isReplay %}style="animation-delay:{{ event.replayOrder * 40 }}ms"{% endif %}>
                <span class="mc-event-badge">{{ services[event.service].emoji ?? '?' }}</span>
                <span class="mc-event-type">{{ event.type }}</span>
                {% if event.payload.amount is defined %}
                <span class="mc-event-meta">${{ event.payload.amount }}{% if event.payload.currency is defined %} {{ event.payload.currency }}{% endif %}</span>
                {% elseif event.payload.user is defined %}
                <span class="mc-event-meta">{{ event.payload.user }}</span>
                {% elseif event.payload.sku is defined %}
                <span class="mc-event-meta">{{ event.payload.sku }} ×{{ event.payload.qty }}</span>
                {% endif %}
                <span class="mc-event-time">{{ event.tsDisplay }}</span>
            </div>
            {% else %}
            <div class="mc-events-empty">Waiting for events…</div>
            {% endfor %}
        </div>
    </div>

</div>
</div>
{% endblock %}

{% block head %}
<style>
/* ─── Mission Control ──────────────────────────────────────────────────────── */

.mc-status-bar {
    display: flex; align-items: center; gap: .75rem;
    padding: .5rem .9rem;
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-md, .5rem);
    font-size: .8rem; margin-bottom: 1rem;
}
.mc-status-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    transition: background .4s, box-shadow .4s;
}
.mc-status-dot.is-connected    { background: #10b981; box-shadow: 0 0 6px #10b981; }
.mc-status-dot.is-disconnected { background: #94a3b8; }
.mc-status-label { font-weight: 500; }
.mc-status-stat  { color: var(--text-2); margin-left: auto; }

/* ─── Flow diagram ─────────────────────────────────────── */
.mc-flow {
    display: flex; align-items: center;
    margin-bottom: 1.1rem; gap: 0;
}
/* Left group (Services + pipe) takes flex:1 so NATS sits exactly in the middle */
.mc-flow-left {
    flex: 1; display: flex; align-items: center;
}
.mc-flow-box {
    display: flex; flex-direction: column; align-items: center; gap: .25rem;
    padding: .45rem .6rem;
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-md, .5rem);
    font-size: .7rem; white-space: nowrap;
}
.mc-flow-box--nats { background: color-mix(in srgb, var(--brand, #6366f1) 8%, var(--surface-2)); }
.mc-flow-box-title { font-weight: 700; font-size: .65rem; text-transform: uppercase; letter-spacing: .05em; color: var(--text-2); }
.mc-flow-nats-badges { display: flex; gap: 3px; }
.mc-flow-svc {
    font-size: .9rem; width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 3px; transition: background .2s;
    position: relative;
}
.mc-flow-svc.is-emitting { background: color-mix(in srgb, var(--svc-color, var(--brand, #6366f1)) 25%, transparent); }

.mc-flow-pipe {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    gap: 4px; padding: 0 6px; min-width: 50px;
}
.mc-pipe-track {
    width: 100%; height: 8px; border-radius: 4px;
    background-image: repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--brand, #6366f1) 55%, transparent) 0,
        color-mix(in srgb, var(--brand, #6366f1) 55%, transparent) 8px,
        transparent 8px, transparent 16px
    );
    animation: pipe-march 1.1s linear infinite;
    transition: background-image .3s, box-shadow .3s;
}
.mc-pipe-label { font-size: .6rem; color: var(--text-2); white-space: nowrap; }
@keyframes pipe-march { from { background-position: 0 0; } to { background-position: 16px 0; } }
.mc-flow-pipe.is-hot .mc-pipe-track {
    animation-duration: .2s;
    background-image: repeating-linear-gradient(
        90deg, #fbbf24 0, #fbbf24 8px, transparent 8px, transparent 16px
    );
    box-shadow: 0 0 8px #fbbf2460;
}

/* ─── Fanout (NATS → two consumers) ───────────────────── */
.mc-flow-fanout {
    display: flex; flex-direction: column; gap: .4rem;
    flex: 1; /* equal weight to the left pipe → NATS stays centred */
}
.mc-flow-fanout-branch {
    display: flex; align-items: center;
}
.mc-flow-fanout-branch .mc-flow-pipe { flex: 1; min-width: 52px; }
.mc-flow-fanout-branch--audit { margin-top: .1rem; }

/* ─── Panels ──────────────────────────────────────────── */
.mc-panels {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .75rem;
}
@media (max-width: 680px) { .mc-panels { grid-template-columns: 1fr; } }
.mc-panel {
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-md, .5rem); padding: .65rem;
    overflow: hidden;
}
.mc-panel-title {
    font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
    color: var(--text-2); margin-bottom: .6rem;
    padding-bottom: .35rem; border-bottom: 1px solid var(--border);
}

/* ─── Service cards ───────────────────────────────────── */
.mc-service-card {
    display: flex; align-items: center; gap: .45rem;
    padding: .35rem .4rem; margin-bottom: .35rem;
    border-radius: .35rem; border: 1px solid transparent;
    transition: border-color .3s, background .3s;
}
.mc-service-card.is-emitting {
    border-color: var(--svc-color, var(--brand, #6366f1));
    background: color-mix(in srgb, var(--svc-color, var(--brand, #6366f1)) 8%, var(--surface-2));
}
.mc-service-card.is-dead { opacity: .5; }
.mc-service-card.is-buffering {
    border-color: #f59e0b;
    animation: buffering-pulse 2s ease-in-out infinite;
}
@keyframes buffering-pulse {
    0%, 100% { box-shadow: 0 0 0 0 #f59e0b30; }
    50%       { box-shadow: 0 0 0 5px #f59e0b30; }
}
.mc-buffering-label { color: #f59e0b; font-style: italic; }
.mc-delivery-badge { font-size: .75rem; margin-left: .2rem; cursor: default; opacity: .65; vertical-align: middle; }
.mc-delivery-badge:hover { opacity: 1; }

.mc-service-dot {
    position: relative; font-size: 1.1rem;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.mc-emit-ring {
    position: absolute; inset: -5px; border-radius: 50%;
    border: 2px solid var(--svc-color, var(--brand, #6366f1));
    animation: ring-expand .8s ease-out forwards;
    pointer-events: none;
}
@keyframes ring-expand {
    0%   { transform: scale(.8); opacity: 1; }
    100% { transform: scale(2.4); opacity: 0; }
}
.mc-service-info  { flex: 1; min-width: 0; }
.mc-service-label { font-weight: 600; font-size: .78rem; }
.mc-service-last  { font-size: .68rem; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mc-service-count { font-size: .65rem; color: var(--text-2); }
.mc-kill-btn, .mc-revive-btn {
    flex-shrink: 0; background: none; border: 1px solid var(--border);
    border-radius: .25rem; padding: .1rem .35rem;
    cursor: pointer; font-size: .75rem; color: var(--text-2); line-height: 1;
    transition: background .15s, border-color .15s;
}
.mc-kill-btn:hover   { background: color-mix(in srgb, #ef4444 12%, transparent); border-color: #ef4444; }
.mc-revive-btn       { border-color: #10b981; color: #10b981; }
.mc-revive-btn:hover { background: color-mix(in srgb, #10b981 12%, transparent); }

/* ─── NATS topology ───────────────────────────────────── */
.mc-nats-row {
    display: flex; align-items: center; gap: .4rem;
    padding: .3rem 0; border-bottom: 1px solid var(--border);
    font-size: .74rem;
}
.mc-nats-row code       { flex: 1; font-size: .7rem; color: var(--brand, #6366f1); }
.mc-nats-row-desc       { color: var(--text-2); font-size: .68rem; white-space: nowrap; }
.mc-nats-badge {
    font-size: .6rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .04em; padding: .1rem .3rem; border-radius: .2rem; flex-shrink: 0;
}
.mc-nats-badge--core { background: color-mix(in srgb, #6366f1 15%, transparent); color: #6366f1; }
.mc-nats-badge--js   { background: color-mix(in srgb, #f59e0b 15%, transparent); color: #b45309; }
.mc-nats-badge--kv   { background: color-mix(in srgb, #10b981 15%, transparent); color: #065f46; }

/* ─── Health grid ─────────────────────────────────────── */
.mc-health-label {
    font-size: .65rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
    color: var(--text-2); margin: .65rem 0 .35rem;
}
.mc-health-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: .3rem;
}
.mc-health-tile {
    position: relative; height: 62px;
    border-radius: .4rem; border: 1px solid var(--border);
    perspective: 600px; transform-style: preserve-3d;
    transition: border-color .4s;
}
.mc-health-tile.is-up   { border-color: #10b981; }
.mc-health-tile.is-warn { border-color: #f59e0b; }
.mc-health-tile.is-down { border-color: #ef4444; }

.mc-health-face {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .1rem;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    transition: transform .55s ease;
    border-radius: .4rem;
}
.mc-health-face--front {
    transform: rotateY(0deg);
    background: var(--surface-2);
}
.mc-health-tile.is-up   .mc-health-face--front { background: color-mix(in srgb, #10b981 12%, var(--surface-2)); }
.mc-health-tile.is-warn .mc-health-face--front { background: color-mix(in srgb, #f59e0b 12%, var(--surface-2)); }
.mc-health-face--back {
    transform: rotateY(180deg);
    background: color-mix(in srgb, #ef4444 18%, var(--surface-2));
}
.mc-health-tile.is-down .mc-health-face--front { transform: rotateY(-180deg); }
.mc-health-tile.is-down .mc-health-face--back  { transform: rotateY(0deg); }

.mc-health-emoji      { font-size: 1.1rem; }
.mc-health-lbl        { font-size: .62rem; font-weight: 600; }
.mc-health-age        { font-size: .58rem; color: var(--text-2); font-variant-numeric: tabular-nums; }
.mc-health-down-label { font-size: .62rem; font-weight: 700; color: #ef4444; letter-spacing: .05em; }

/* ─── Event stream ────────────────────────────────────── */
.mc-panel--stream { display: flex; flex-direction: column; }
.mc-events {
    flex: 1; overflow-y: auto; max-height: 330px;
    display: flex; flex-direction: column; gap: 2px;
}
.mc-events-empty { color: var(--text-2); font-size: .8rem; text-align: center; padding: 1rem 0; }

@keyframes mc-slide-in {
    from { transform: translateY(-8px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}

.mc-event {
    display: flex; align-items: center; gap: .35rem;
    padding: .28rem .4rem; border-radius: .3rem;
    font-size: .73rem; background: var(--surface-1);
    border: 1px solid transparent; border-left-width: 3px;
    transition: border-color .2s;
}
.mc-event.is-new    { animation: mc-slide-in .3s ease-out; }
.mc-event.is-replay {
    border-color: var(--brand, #6366f1) !important;
    background: color-mix(in srgb, var(--brand, #6366f1) 6%, var(--surface-1));
    animation: mc-slide-in .3s ease-out backwards;
}
.mc-svc-orders    { border-left-color: #6366f1; }
.mc-svc-payments  { border-left-color: #f59e0b; }
.mc-svc-auth      { border-left-color: #10b981; }
.mc-svc-inventory { border-left-color: #ef4444; }

.mc-event-badge { font-size: .82rem; flex-shrink: 0; }
.mc-event-type  { font-weight: 500; flex: 1; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mc-event-meta  { color: var(--text-2); font-size: .68rem; flex-shrink: 0; }
.mc-event-time  { color: var(--text-2); font-size: .67rem; font-variant-numeric: tabular-nums; flex-shrink: 0; margin-left: auto; }
</style>
{% endblock %}
