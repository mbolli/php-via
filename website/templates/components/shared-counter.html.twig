<div class="shared-counter demo-box" id="shared-counter">
    <div class="demo-box-label">Live counter — shared with everyone on this page</div>
    <div class="counter-value" data-text="${{ counter_id }}">
        {{ counter_val }}
    </div>
    <button class="counter-btn" data-on:click="@post('{{ increment_url }}')">
        +1
    </button>
    <div class="counter-last-click" data-text="${{ last_click_id }} ? 'Last click: ' + ${{ last_click_id }} : ''">
        {{ last_click_val }}
    </div>
</div>
