{% extends 'shells/base.html.twig' %}
{% block title %}Examples — php-via{% endblock %}
{% block content %}
<section class="page-section">
    <div class="section-label">See it in action</div>
    <h1 class="section-title">Live Examples</h1>
    <p class="section-lead">
        Interactive demos running inside this website. Click any card to try it — live code on the left, source on the right.
    </p>

    {% set examples = [
        {
            title: '⚡ Counter',
            href: 'examples/counter',
            difficulty: 'Beginner',
            description: 'Counter with configurable step. Uses data-bind for two-way input binding.',
        },
        {
            title: '👋 Greeter',
            href: 'examples/greeter',
            difficulty: 'Beginner',
            description: 'Form inputs, multiple actions, and signal updates with Twig templates.',
        },
        {
            title: '🔀 Path Parameters',
            href: 'examples/path-params',
            difficulty: 'Beginner',
            description: 'Dynamic routing with automatic type-cast parameter injection.',
        },
        {
            title: '🔭 All Scopes',
            href: 'examples/all-scopes',
            difficulty: 'Beginner',
            multiplayer: true,
            description: 'See TAB, ROUTE, and GLOBAL scopes working together on one page.',
        },
        {
            title: '🔍 Live Search',
            href: 'examples/live-search',
            difficulty: 'Beginner',
            description: 'Type to filter PHP stdlib functions server-side. Every keystroke is a round-trip — no search logic shipped to the browser.',
        },
        {
            title: '✓ Todo List',
            href: 'examples/todo',
            difficulty: 'Intermediate',
            multiplayer: true,
            description: 'Multiplayer todo app. One shared list for all connected clients — ROUTE scope.',
        },
        {
            title: '🧩 Components',
            href: 'examples/components',
            difficulty: 'Intermediate',
            description: 'Three independent counters on one page. Each is an isolated component with its own signals.',
        },
        {
            title: '👁️ Client Monitor',
            href: 'examples/client-monitor',
            difficulty: 'Intermediate',
            multiplayer: true,
            description: 'Live dashboard of connected clients with identicons, IPs, and render statistics.',
        },
        {
            title: '🛒 Shopping Cart',
            href: 'examples/shopping-cart',
            difficulty: 'Intermediate',
            description: 'SESSION-scoped cart persists across browser tabs. Open a new tab — it\'s already there. No localStorage, no Redux.',
        },
        {
            title: '🪄 Multi-step Form',
            href: 'examples/wizard',
            difficulty: 'Intermediate',
            description: '3-step dev identity card wizard. All form state lives server-side — no session cookies, no localStorage, no hydration.',
        },
        {
            title: '🔐 Login Flow',
            href: 'examples/login',
            difficulty: 'Intermediate',
            description: 'Persistent login state across page refreshes using sessionData. Refresh while logged in — you stay logged in. A signal can\'t do that.',
        },
        {
            title: '📈 Stock Ticker',
            href: 'examples/stock-ticker',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Real-time stock prices with ECharts visualization. Timer-based route-scoped broadcasting.',
        },
        {
            title: '💬 Chat Room',
            href: 'examples/chat-room',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Multi-room chat with custom scopes, typing indicators, and session-based usernames.',
        },
        {
            title: '🎮 Game of Life',
            href: 'examples/game-of-life',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Multiplayer Conway\'s Game of Life. Everyone draws and evolves the same board.',
        },
        {
            title: '🎨 Theme Builder',
            href: 'examples/theme-builder',
            difficulty: 'Advanced',
            description: 'Click swatches to repaint a preview card. Undo/redo powered by a PHP array index — no client history stack.',
        },
        {
            title: '🔨 Live Auction',
            href: 'examples/live-auction',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Timed auction with server-side countdown and anti-snipe protection. Place a bid — the clock and winner banner update for every viewer in real time.',
        },
        {
            title: '⌨️ Type Race',
            href: 'examples/type-race',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Race to type a PHP snippet first. Progress bars and WPM update live for all racers. No client logic — the server owns every character.',
        },
        {
            title: '🛰 NATS Visualizer',
            href: 'examples/mission-control',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Four simulated microservices publish events over NATS. Core pub/sub, JetStream durable consumers (guaranteed delivery), and KV health heartbeats — zero JavaScript.',
        },
        {
            title: '📊 Spreadsheet',
            href: 'examples/spreadsheet',
            difficulty: 'Advanced',
            multiplayer: true,
            description: 'Collaborative spreadsheet with SQLite persistence, virtual scrolling, and multi-user cursors.',
        },
    ] %}

    <div class="examples-grid">
        {% for example in examples %}
        <a class="example-card" href="{{ basePath }}{{ example.href }}">
            <h3>{{ example.title }}</h3>
            <div class="description">{{ example.description }}</div>
            <div class="meta">
                <span class="badge badge-{{ example.difficulty | lower }}">{{ example.difficulty }}</span>
                {% if example.multiplayer | default(false) %}<span class="badge badge-multiplayer">👥 Multiplayer</span>{% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
</section>
{% endblock %}
