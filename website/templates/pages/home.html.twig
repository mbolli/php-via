{% extends 'shells/base.html.twig' %}
{% block title %}php-via — Real-time PHP. No JavaScript. No build step.{% endblock %}
{% block head %}<meta name="description" content="php-via is a real-time engine for building reactive PHP web applications with Swoole and Datastar. No JavaScript, no build step, multiplayer by default.">{% endblock %}
{% block content %}
<!-- Hero -->
<section class="hero">
    <div class="hero-inner">
        <div class="hero-eyebrow">
            <span>⚡</span> Real-time PHP
        </div>

        <h1>
            PHP finally has<br>
            <em>real-time superpowers.</em>
        </h1>

        <p class="hero-tagline">
            php-via turns your PHP into a reactive, multiplayer-ready server.
            No JavaScript. No build step. No API layer. Just PHP and Swoole.
        </p>

        {{ presence | raw }}

        <div class="hero-ctas">
            <a href="/docs/getting-started" class="btn btn-primary">Get started →</a>
            <a href="https://github.com/mbolli/php-via" class="btn btn-secondary" target="_blank" rel="noopener">
