{% extends 'shells/docs.html.twig' %}
{% block title %}Scopes — php-via Docs{% endblock %}
{% block content %}
<article class="docs-content">
    <h1>Scopes</h1>
    <p>
        The scope system is php-via's killer feature. A scope determines <em>which clients share a signal</em>.
        Change one line and state that was private becomes multiplayer.
    </p>

    <h2 id="scope-types">Scope types</h2>

    <table style="width: 100%; border-collapse: collapse; font-size: var(--font-size-0); margin-block: var(--size-5);">
        <thead>
            <tr style="border-block-end: 2px solid var(--border);">
                <th style="text-align: left; padding: var(--size-2) var(--size-3); font-weight: var(--font-weight-7);">Scope</th>
                <th style="text-align: left; padding: var(--size-2) var(--size-3); font-weight: var(--font-weight-7);">Shared with</th>
                <th style="text-align: left; padding: var(--size-2) var(--size-3); font-weight: var(--font-weight-7);">Use case</th>
            </tr>
        </thead>
        <tbody>
            <tr style="border-block-end: 1px solid var(--border);">
                <td style="padding: var(--size-2) var(--size-3);"><code>Scope::TAB</code></td>
                <td style="padding: var(--size-2) var(--size-3);">Nobody — this tab only</td>
                <td style="padding: var(--size-2) var(--size-3);">Personal UI state, form input</td>
            </tr>
            <tr style="border-block-end: 1px solid var(--border);">
                <td style="padding: var(--size-2) var(--size-3);"><code>Scope::ROUTE</code></td>
                <td style="padding: var(--size-2) var(--size-3);">Every user on same URL</td>
                <td style="padding: var(--size-2) var(--size-3);">Live feeds, shared boards, todo lists</td>
            </tr>
            <tr style="border-block-end: 1px solid var(--border);">
                <td style="padding: var(--size-2) var(--size-3);"><code>Scope::SESSION</code></td>
                <td style="padding: var(--size-2) var(--size-3);">All of this user's tabs</td>
                <td style="padding: var(--size-2) var(--size-3);">User preferences, auth state</td>
            </tr>
            <tr style="border-block-end: 1px solid var(--border);">
                <td style="padding: var(--size-2) var(--size-3);"><code>Scope::GLOBAL</code></td>
                <td style="padding: var(--size-2) var(--size-3);">Every connected client, every route</td>
                <td style="padding: var(--size-2) var(--size-3);">Site-wide banners, system notifications</td>
            </tr>
            <tr>
                <td style="padding: var(--size-2) var(--size-3);"><code>'room:lobby'</code></td>
                <td style="padding: var(--size-2) var(--size-3);">Clients you add to this custom scope</td>
                <td style="padding: var(--size-2) var(--size-3);">Chat rooms, collaborative documents, teams</td>
            </tr>
        </tbody>
    </table>

    <h2 id="setting-a-scope">Setting a scope</h2>
    {% code 'php' %}{% verbatim %}
// Set the context's primary scope
$c->scope(Scope::ROUTE);

// Add a secondary scope (this context belongs to both)
$c->addScope('room:lobby');
{% endverbatim %}{% endcode %}
    <p>
        Calling <code>$c-&gt;scope()</code> with <code>Scope::ROUTE</code> expands to the actual route path automatically.
        So on <code>/blog/post-1</code>, it becomes <code>route:/blog/post-1</code>.
    </p>

    <h2 id="broadcasting">Broadcasting</h2>
    <p>When signals change inside an action, clients in the same scope get updated automatically. To push updates from outside an action (e.g., a timer):</p>
    {% code 'php' %}{% verbatim %}
// Push to all clients on this route
$app->broadcast(Scope::routeScope('/'));

// Push to a custom scope
$app->broadcast('room:lobby');
{% endverbatim %}{% endcode %}

    <div class="docs-demo">
        <div class="docs-demo-header">▶ TAB vs ROUTE — feel the difference</div>
        <div class="docs-demo-body">
            <p style="font-size: var(--font-size-0); color: var(--text-3); margin-block-end: var(--size-4);">
                Open a second tab, then increment both sides. One is private to you; one goes to everyone.
            </p>
            {{ demo | raw }}
        </div>
    </div>

    <h2 id="custom-scopes">Custom scopes</h2>
    <p>You can create any custom scope string. Clients that share the same scope string receive each other's broadcasts:</p>
    {% code 'php' %}{% verbatim %}
$roomId = $request->getQueryParam('room');
$roomScope = 'room:' . $roomId;

$c->addScope($roomScope);

// All clients in this room get the update
$app->broadcast($roomScope);
{% endverbatim %}{% endcode %}
    <p>See the <a href="/examples">chat room example</a> for a full implementation.</p>
</article>

{% endblock %}
