{% extends 'shells/docs.html.twig' %}
{% block title %}Templates — php-via Docs{% endblock %}
{% block content %}
<article>
    <h1>Templates</h1>
    <p>
        php-via supports two rendering paths that serve different purposes and can be mixed freely in the same app.
    </p>

    <h2 id="two-paths">Two rendering paths</h2>
    <div class="code-result-split" style="align-items: start;">
        <div>
            <h3 style="margin-block-start:0">Shell — <code>shell.html</code></h3>
            <p>
                A static <code>.html</code> file set with <code>withShellTemplate()</code>.
                php-via performs a simple string replacement of
                {% verbatim %}<code>{{ placeholder }}</code>{% endverbatim %} tokens —
                <strong>not Twig</strong>. The shell is sent once per page load and never re-sent over SSE.
                Use it for the outer chrome: doctype, nav, scripts, footer.
            </p>
            {% code 'html' %}{% verbatim %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta data-signals='{{ signals_json }}'>
    {{ head_content }}
</head>
<body>
    {{ content }}
    <script type="module"
        src=".../datastar.js"></script>
    {{ foot_content }}
</body>
</html>
            {% endverbatim %}{% endcode %}
        </div>
        <div>
            <h3 style="margin-block-start:0">Views — Twig or closure</h3>
            <p>
                The page content, set with <code>$c-&gt;view()</code>.
                Re-rendered on every SSE update. Can be a Twig template
                (requires <code>withTemplateDir()</code>) or a plain PHP closure.
            </p>
            {% code 'php' %}{% verbatim %}
// Twig template (string name)
$c->view('counter.html.twig', [
    'count' => $count->int(),
    'id'    => $count->id(),
]);

// PHP closure — no Twig needed
$c->view(function () use ($count): string {
    return '<p>' . $count->int() . '</p>';
});
            {% endverbatim %}{% endcode %}
        </div>
    </div>

    <h3 id="twig-shell">Alternative: Twig as the shell</h3>
    <p>
        Instead of a static <code>shell.html</code>, you can create your own Twig base template that
        defines the full outer document using Twig blocks. When a view extends it, Twig renders
        the complete <code>&lt;html&gt;...&lt;/html&gt;</code> document — php-via detects this and skips
        the plain-HTML shell entirely.
    </p>
    {% code 'twig' %}{% verbatim %}
{# templates/base.html.twig — you create this #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta data-signals='{"via_ctx":"{{ contextId }}","_disconnected":false}'>
    <title>{% block title %}{% endblock %}</title>
</head>
<body>
    <nav>...shared nav...</nav>
    <main>{% block content %}{% endblock %}</main>
    <script type="module" src="/datastar.js"></script>
</body>
</html>
    {% endverbatim %}{% endcode %}
    {% code 'twig' %}{% verbatim %}
{# templates/my-page.html.twig #}
{% extends "base.html.twig" %}

{% block title %}My App{% endblock %}

{% block content %}
    <h1>Hello</h1>
{% endblock %}
    {% endverbatim %}{% endcode %}
    <p>
        The key variable is <code>{% verbatim %}{{ contextId }}{% endverbatim %}</code>, which is injected
        automatically by <code>Context::render()</code>. Don't confuse it with
        <code>{% verbatim %}{{ context_id }}{% endverbatim %}</code>, which is the <code>HtmlBuilder</code>
        placeholder for the plain-HTML shell path.
    </p>
    <p>
        This path is a good fit when you want Twig inheritance across multiple pages but don't need
        a separate static shell file.
        The downside: the base template is re-rendered on every SSE update (unlike a shell,
        which is sent once), so keep it lightweight.
    </p>

    <h2 id="setup">Setup</h2>
    <p>Configure the template directory and optional shell in <code>Config</code>:</p>
    {% code 'php' %}{% verbatim %}
$app = new Via(
    (new Config())
        ->withTemplateDir(__DIR__ . '/templates')    // Twig views
        ->withShellTemplate(__DIR__ . '/shell.html') // optional plain-HTML shell
);
    {% endverbatim %}{% endcode %}
    <p>Skip <code>withTemplateDir()</code> if you use only PHP closures for views, and skip <code>withShellTemplate()</code> if your views extend <code>base.html.twig</code>.</p>

    <h2 id="passing-data">Passing data to templates</h2>
    <p>
        Signals and actions are <strong>auto-injected</strong> into every Twig render. You don't need to pass them
        manually — just register them and they're available by name:
    </p>
    {% code 'php' %}{% verbatim %}
$count = $c->signal(0, 'count');
$inc   = $c->action(fn() => $count->setValue($count->int() + 1), 'inc');

// Signal 'count' → {{ count }}  (a Signal object, call .int, .string, .id(), .url(), …)
// Action 'inc'   → {{ inc }}    (an Action object, call .url)
$c->view('counter.html.twig'); // no data needed

// Only pass data that isn't a signal or action:
$c->view('todo.html.twig', ['todos' => $todos]);
    {% endverbatim %}{% endcode %}
    <p>
        Explicit entries in the <code>$data</code> array take priority over auto-injected values —
        useful when you need to pass a derived or renamed value for a specific render.
    </p>

    <h2 id="reactive-text">Reactive text</h2>
    <p>Use <code>data-text</code> to keep an element in sync with a signal. Always seed the initial value to avoid a flash:</p>
    {% code 'html' %}{% verbatim %}
<!-- counter.html.twig — count is auto-injected as a Signal object -->
<span data-text="${{ count.id() }}">{{ count.int }}</span>
    {% endverbatim %}{% endcode %}

    <p>Or use <code>$signal-&gt;text()</code> in PHP to generate the span directly, then output with <code>| raw</code>:</p>
    {% code 'php' %}{% verbatim %}
$c->view('counter.html.twig', [
    'count_span' => $count->text(), // '<span data-text="$count"></span>'
]);
    {% endverbatim %}{% endcode %}
    {% code 'html' %}{% verbatim %}
{{ count_span | raw }}
    {% endverbatim %}{% endcode %}

    <h2 id="two-way-binding">Two-way binding</h2>
    <p>Use <code>data-bind</code> for inputs that should reflect <em>and update</em> a signal:</p>
    {% code 'html' %}{% verbatim %}
<!-- name is auto-injected as a Signal object -->
<input data-bind="{{ name.id() }}" type="text">

<!-- Or use the bind() Twig function with the auto-injected Signal: -->
<input {{ bind(name) }} type="text">
    {% endverbatim %}{% endcode %}

    <h2 id="actions">Triggering actions</h2>
    <p>Use Datastar's event attributes to POST to an action URL:</p>
    {% code 'html' %}{% verbatim %}
<!-- inc is auto-injected as an Action object -->
<button data-on:click="@post('{{ inc.url }}')">+1</button>

<!-- Pass data via query params -->
<button data-on:click="@post('{{ vote.url }}?option=tab')">Vote TAB</button>
    {% endverbatim %}{% endcode %}

    <h2 id="template-inheritance">Template inheritance</h2>
    <p>Standard Twig inheritance works as expected:</p>
    {% code 'twig' %}{% verbatim %}
{# base.html.twig #}
<nav><a href="/">Home</a></nav>
<main>{% block content %}{% endblock %}</main>
    {% endverbatim %}{% endcode %}
    {% code 'twig' %}{% verbatim %}
{# page.html.twig #}
{% extends "base.html.twig" %}
{% block content %}
    <h1>My page</h1>
{% endblock %}
    {% endverbatim %}{% endcode %}

    <h3 id="block-updates">Blocks as SSE update targets</h3>
    <p>
        When you name a Twig block, you can tell <code>$c-&gt;view()</code> to send <em>only</em> that
        block on SSE updates while still rendering the full template on the initial page load:
    </p>
    {% code 'php' %}{% verbatim %}
$c->view(fn () => $c->render('page.html.twig', $data), block: 'demo');
    {% endverbatim %}{% endcode %}
    <p>
        This keeps SSE payloads small — the outer layout, nav, and static content are sent once on
        page load and never re-transmitted. Wrap the block content in
        <code>&lt;div id="via-block-{name}"&gt;</code> so Datastar can target it.
        See <a href="/docs/views#partial-updates">Views → Partial updates</a> for details.
    </p>

    <h2 id="cache-updates">Disabling view caching</h2>
    <p>
        php-via caches view renders and skips re-rendering if signals haven't changed.
        Disable this when your view reads external state (e.g. <code>getClients()</code>):
    </p>
    {% code 'php' %}{% verbatim %}
$c->view('presence.html.twig', ['count' => count($app->getClients())], cacheUpdates: false);
    {% endverbatim %}{% endcode %}

    <h2 id="debugging">Debugging</h2>
    <p>The <code>dump()</code> Twig function renders any variable as a <code>&lt;pre&gt;</code> block:</p>
    {% code 'html' %}{% verbatim %}
{{ dump(some_variable) }}
    {% endverbatim %}{% endcode %}

    <h2 id="next-steps">Next steps</h2>
    <ul>
        <li><a href="/docs/signals">Signals</a> — reactive state primitives</li>
        <li><a href="/docs/actions">Actions</a> — server-side event handlers</li>
        <li><a href="/docs/views">Views</a> — view lifecycle and caching</li>
        <li><a href="/docs/api">API Reference</a> — complete method signatures</li>
    </ul>
</article>
{% endblock %}
